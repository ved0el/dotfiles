# Tools profile — modern CLI tools, managed by mise (cross-platform: one list works
# on macOS, Ubuntu, and Raspberry Pi/ARM, no per-OS package-name gaps). `mise install`
# (run by the chezmoi bootstrap) installs everything declared here. Pin versions
# instead of "latest" if you want reproducibility.
[tools]
bat = "latest"
bottom = "latest"
delta = "latest"
# eza: plain registry tool on macOS/Linux. Windows uses the aqua prebuilt binary
# (conf.d/windows.toml) because the registry default is cargo:eza — a source build
# with no Windows-friendly binary.
{{ if ne .chezmoi.os "windows" -}}
eza = "latest"
{{ end -}}
fd = "latest"
fzf = "latest"
gh = "latest"
jq = "latest"
ripgrep = "latest"
sd = "latest"
yq = "latest"
zoxide = "latest"
