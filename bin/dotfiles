#!/usr/bin/env bash

# =============================================================================
# Dotfiles Manager - Clean, Cross-Platform Installation Script
# =============================================================================
# Features: Interactive/Non-interactive, Profile-based, Cross-platform
# Supports: macOS (Darwin), Linux (Ubuntu, Fedora, Arch, etc.)
# Author: Veteran Programmer - Clean, Maintainable, Production-Ready Code
# =============================================================================

# Enable strict error handling
set -euo pipefail

# =============================================================================
# Configuration & Constants
# =============================================================================
readonly DEFAULT_ROOT="$HOME/.dotfiles"
readonly DEFAULT_PROFILE="core"
readonly DEFAULT_VERBOSE="false"
readonly DEFAULT_EXCLUDE=""
readonly DEFAULT_EXTRA=""
readonly SCRIPT_NAME="dotfiles"

# URLs - Easy to update
readonly REPO_URL="https://github.com/ved0el/dotfiles.git"
readonly INSTALL_COMMAND_URL="https://tinyurl.com/get-dotfiles"
readonly DOCS_URL="https://github.com/ved0el/dotfiles"

# Configuration file location
readonly CONFIG_FILE="$HOME/.zshenv"

# =============================================================================
# Cross-Platform Detection & Utilities
# =============================================================================
get_os_type() { uname -s; }

# Cross-platform sed in-place editing
sed_inplace() {
    local file="$1"; shift
    [[ "$(get_os_type)" == "Darwin" ]] && sed -i '' "$@" "$file" || sed -i "$@" "$file"
}

# Extract value from a saved config line. Handles three forms:
#   export VAR=value
#   export VAR="value"
#   export VAR="${VAR:-default}"   # env-override pattern from save_config
#
# For the third form, env-passed values win and the embedded default is used as
# fallback. Without this branch the literal pattern would be exported verbatim.
extract_config_value() {
    local var_name="$1"
    local config_file="$2"

    local line
    line=$(grep "^export ${var_name}=" "$config_file" 2>/dev/null | tail -1 || echo "")
    [[ -z "$line" ]] && return 1

    # Strip "export VAR=" prefix, then strip ALL surrounding quotes.
    # Using loops instead of single-strip to handle stacked extra quotes
    # (e.g. "value""" from a corrupted file) without leaving residue.
    local value="${line#*=}"
    while [[ "${value:0:1}" == '"' || "${value:0:1}" == "'" ]]; do value="${value:1}"; done
    while [[ "${value: -1:1}" == '"' || "${value: -1:1}" == "'" ]]; do value="${value%?}"; done

    # Resolve ${SAME_VAR:-default} fallback syntax safely (no eval).
    if [[ "$value" == '${'"$var_name"':-'*'}' ]]; then
        local env_val="${!var_name:-}"
        if [[ -n "$env_val" ]]; then
            value="$env_val"
        else
            value="${value#'${'"$var_name"':-'}"
            value="${value%'}'}"
        fi
    fi

    [[ -n "$value" ]] && echo "$value"
}

# =============================================================================
# Shared logging — colors, glyphs, _dotfiles_log_* helpers
# =============================================================================
# Source the POSIX log library. DOTFILES_ROOT may not be set yet (we're before
# init_script), so fall back to a hard-coded default that matches the install
# pattern.
_DF_LIB="${DOTFILES_ROOT:-$HOME/.dotfiles}/zsh/lib/log.sh"
if [[ -f "$_DF_LIB" ]]; then
    # shellcheck source=../zsh/lib/log.sh
    . "$_DF_LIB"
else
    # Last-resort fallback — _log.sh not present (fresh-machine bootstrap or
    # DOTFILES_ROOT points elsewhere). Define empty color vars and minimal log
    # stubs so `set -u` is happy and the script can still run.
    _DF_BOLD=''; _DF_RESET=''; _DF_RED=''; _DF_GREEN=''
    _DF_YELLOW=''; _DF_BLUE=''; _DF_MAGENTA=''; _DF_CYAN=''
    _DF_WHITE=''; _DF_GRAY=''
    _DF_CHECK='✓'; _DF_CROSS='✗'; _DF_ARROW='→'; _DF_BULLET='•'; _DF_WARN='⚠'
    _dotfiles_log_info()    { :; }
    _dotfiles_log_debug()   { :; }
    _dotfiles_log_dim()     { :; }
    _dotfiles_log_success() { :; }
    _dotfiles_log_step()    { echo "→ $*"; }
    _dotfiles_log_detail()  { echo "• $*"; }
    _dotfiles_log_result()  { echo "  $1: $2"; }
    _dotfiles_log_summary() { echo "✓ $*"; }
    _dotfiles_log_warning() { echo "⚠  $*" >&2; }
    _dotfiles_log_error()   { echo "✗ $*" >&2; }
    _dotfiles_log_hint()    { echo "  hint: $*" >&2; }
fi
unset _DF_LIB

# Optional bash-only UI primitives (spinner, table, badge, progress,
# did-you-mean). Sourced after log.sh so the semantic palette is available.
_DF_UI_LIB="${DOTFILES_ROOT:-$HOME/.dotfiles}/zsh/lib/ui.sh"
if [[ -f "$_DF_UI_LIB" ]]; then
    # shellcheck source=../zsh/lib/ui.sh
    . "$_DF_UI_LIB"
fi
unset _DF_UI_LIB

# Local aliases for shorter color/glyph references in this script
readonly RED="$_DF_RED" GREEN="$_DF_GREEN" YELLOW="$_DF_YELLOW"
readonly BLUE="$_DF_BLUE" MAGENTA="$_DF_MAGENTA" CYAN="$_DF_CYAN"
readonly WHITE="$_DF_WHITE" GRAY="$_DF_GRAY"
readonly BOLD="$_DF_BOLD" DIM="$_DF_DIM" RESET="$_DF_RESET"
readonly CHECK="$_DF_CHECK" CROSS="$_DF_CROSS"
readonly ARROW="$_DF_ARROW" BULLET="$_DF_BULLET"

is_verbose() {
    [[ "${DOTFILES_VERBOSE:-$DEFAULT_VERBOSE}" == "true" ]]
}

is_quiet() {
    [[ "${DOTFILES_QUIET:-false}" == "true" ]]
}

# =============================================================================
# Validation Functions
# =============================================================================
# =============================================================================
# Profile resolution — single source of truth, derived from filesystem
# =============================================================================
# `core` is always implicit. Any other profile is valid iff
# $DOTFILES_ROOT/zsh/packages/<name>/ exists.
# Legacy aliases (NFR-D — kept for at least one major version):
#   `minimal` → `core`, `full` → `develop`, `dev` → `develop`.
# Migrated by set_defaults on next CLI invocation.
# -----------------------------------------------------------------------------

# List valid profile names (one per line).
list_valid_profiles() {
    local pkgs_root="$DOTFILES_ROOT/zsh/packages"
    echo core
    [[ -d "$pkgs_root" ]] || return 0
    local d name
    for d in "$pkgs_root"/*/; do
        [[ -d "$d" ]] || continue
        name="$(basename "$d")"
        [[ "$name" == "core" ]] && continue
        echo "$name"
    done
}

# Echo the package directories that belong to a given profile, in load order.
# Cumulative: server includes core; develop includes server+core.
dotfiles_profile_dirs() {
    local profile="$1"
    local pkgs_root="$DOTFILES_ROOT/zsh/packages"
    case "$profile" in
        minimal|core)
            echo "$pkgs_root/core"
            ;;
        server)
            echo "$pkgs_root/core"
            [[ -d "$pkgs_root/server" ]] && echo "$pkgs_root/server"
            ;;
        full|dev|develop)
            echo "$pkgs_root/core"
            [[ -d "$pkgs_root/server" ]] && echo "$pkgs_root/server"
            [[ -d "$pkgs_root/develop" ]] && echo "$pkgs_root/develop"
            ;;
        *)
            echo "$pkgs_root/core"
            ;;
    esac
}

# Validate profile value (returns 0 if valid, 1 if invalid).
validate_profile() {
    local profile="$1"
    local valid
    valid="$(list_valid_profiles | tr '\n' ' ')"
    local p
    for p in $valid; do
        [[ "$profile" == "$p" ]] && return 0
    done
    _dotfiles_log_error "Invalid profile '$profile'. Valid profiles: ${valid% }"
    _dotfiles_log_hint "try: dotfiles config set profile <name>"
    return 1
}

is_interactive() { [[ -t 0 && -t 1 ]]; }

die() { _dotfiles_log_error "$1"; exit 1; }

# =============================================================================
# Banner & UI Functions
# =============================================================================
show_banner() {
    is_quiet && return 0
    [[ "${DOTFILES_NO_BANNER:-false}" == "true" ]] && return 0
    echo -e "${BOLD}${BLUE}╭────────────────────────────────────────────────────────────────╮${RESET}"
    echo -e "${BOLD}${BLUE}│${RESET}                    ${BOLD}${WHITE}🚀 Dotfiles Manager${RESET}                         ${BOLD}${BLUE}│${RESET}"
    echo -e "${BOLD}${BLUE}│${RESET}              ${GRAY}Clean, Cross-Platform Setup${RESET}                       ${BOLD}${BLUE}│${RESET}"
    echo -e "${BOLD}${BLUE}╰────────────────────────────────────────────────────────────────╯${RESET}"
    echo
}

# Show section header (always-print — CLI progress marker)
show_section() {
    is_quiet && return 0
    echo; echo -e "${BOLD}${MAGENTA}◆ $1${RESET}"
    echo -e "${GRAY}────────────────────────────────────────────────────────────────${RESET}"
}

# Show subsection header (only in verbose mode)
show_subsection() {
    is_verbose || return 0
    echo -e "${CYAN}${BULLET}${RESET} ${BOLD}${CYAN}$1${RESET}";
}

# =============================================================================
# Configuration Management
# =============================================================================
# Set default values for all dotfiles variables.
# Also runs a one-time migration: legacy profile names (minimal/server) are
# upgraded to their replacements (core/full) and persisted to ~/.zshenv.
# Order matters: init_script calls load_config BEFORE set_defaults, so the
# legacy value (if any) is already exported by the time this runs.
set_defaults() {
    export DOTFILES_ROOT="${DOTFILES_ROOT:-$DEFAULT_ROOT}"
    export DOTFILES_PROFILE="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    export DOTFILES_VERBOSE="${DOTFILES_VERBOSE:-$DEFAULT_VERBOSE}"
    export DOTFILES_EXCLUDE="${DOTFILES_EXCLUDE:-$DEFAULT_EXCLUDE}"
    export DOTFILES_EXTRA="${DOTFILES_EXTRA:-$DEFAULT_EXTRA}"

    # One-time profile-name migration (legacy → new). save_config persists.
    # NFR-D: legacy aliases keep working for at least one major version.
    #   minimal  → core    (old "thin" profile renamed)
    #   full     → develop (full split into server/develop; full now points to develop)
    #   dev      → develop (renamed for clarity: develop > server > core supersets)
    local _migrated_profile=""
    case "${DOTFILES_PROFILE:-}" in
        minimal) _migrated_profile="core" ;;
        full)    _migrated_profile="develop" ;;
        dev)     _migrated_profile="develop" ;;
    esac
    if [[ -n "$_migrated_profile" ]]; then
        _dotfiles_log_warning "DOTFILES_PROFILE '${DOTFILES_PROFILE}' migrated to '${_migrated_profile}' — saved to ${CONFIG_FILE}"
        export DOTFILES_PROFILE="$_migrated_profile"
        save_config
    fi
}

load_config() {
    [[ ! -f "$CONFIG_FILE" ]] && return 0

    local value

    if value=$(extract_config_value "DOTFILES_ROOT" "$CONFIG_FILE" 2>/dev/null || true); then
        [[ -n "$value" ]] && export DOTFILES_ROOT="$value"
    fi

    if value=$(extract_config_value "DOTFILES_PROFILE" "$CONFIG_FILE" 2>/dev/null || true); then
        [[ -n "$value" ]] && export DOTFILES_PROFILE="$value"
    fi

    if value=$(extract_config_value "DOTFILES_VERBOSE" "$CONFIG_FILE" 2>/dev/null || true); then
        [[ -n "$value" ]] && export DOTFILES_VERBOSE="$value"
    fi
    # exclude/extra are per-machine overrides (UC-7). Allow empty values
    # to round-trip: an explicit "" in the file means "no override active".
    # Use file-read directly since extract_config_value gates on non-empty.
    value="$(_config_read_file DOTFILES_EXCLUDE)"
    export DOTFILES_EXCLUDE="$value"
    value="$(_config_read_file DOTFILES_EXTRA)"
    export DOTFILES_EXTRA="$value"
}

# Render the managed block (with BEGIN/END markers). Values are written using
# the ${VAR:-default} fallback pattern so env-passed values still win over
# saved defaults (see extract_config_value for the matching reader).
_render_managed_block() {
    local _root="${DOTFILES_ROOT:-$DEFAULT_ROOT}"
    local _profile="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    local _verbose="${DOTFILES_VERBOSE:-$DEFAULT_VERBOSE}"
    local _exclude="${DOTFILES_EXCLUDE:-$DEFAULT_EXCLUDE}"
    local _extra="${DOTFILES_EXTRA:-$DEFAULT_EXTRA}"
    cat << EOF
# DOTFILES MANAGED BEGIN — do not edit between markers; use \`dotfiles config set\`
export DOTFILES_ROOT="\${DOTFILES_ROOT:-$_root}"
export DOTFILES_PROFILE="\${DOTFILES_PROFILE:-$_profile}"
export DOTFILES_VERBOSE="\${DOTFILES_VERBOSE:-$_verbose}"
export DOTFILES_EXCLUDE="\${DOTFILES_EXCLUDE:-$_exclude}"
export DOTFILES_EXTRA="\${DOTFILES_EXTRA:-$_extra}"
# DOTFILES MANAGED END
EOF
}

save_config() {
    # Ensure config directory exists
    local config_dir
    config_dir=$(dirname "$CONFIG_FILE")
    [[ ! -d "$config_dir" ]] && mkdir -p "$config_dir"

    # Single backup, overwritten each save.
    if [[ -f "$CONFIG_FILE" ]]; then
        cp "$CONFIG_FILE" "${CONFIG_FILE}.backup" 2>/dev/null || true
    fi
    # Migration: remove legacy rotated backups. Safe no-op if absent.
    rm -f "${CONFIG_FILE}.backup.1" "${CONFIG_FILE}.backup.2" "${CONFIG_FILE}.backup.3" 2>/dev/null || true

    local block
    block="$(_render_managed_block)"

    if [[ -f "$CONFIG_FILE" ]] && grep -q "^# DOTFILES MANAGED BEGIN" "$CONFIG_FILE"; then
        # Markers exist: replace only between them. Preserves all other
        # user-added content in ~/.zshenv. Implemented as three sed slices
        # because BSD awk (macOS default) rejects newlines inside `-v` values
        # — passing the multi-line $block via -v block="$block" produced
        # "awk: newline in string ..." on every save_config.
        local _tmp
        _tmp="$(mktemp "${CONFIG_FILE}.XXXXXX")" || return 1
        {
            sed -n '/^# DOTFILES MANAGED BEGIN/q;p' "$CONFIG_FILE"
            printf '%s\n' "$block"
            sed -n '/^# DOTFILES MANAGED END/,$p' "$CONFIG_FILE" | tail -n +2
        } > "$_tmp" && mv "$_tmp" "$CONFIG_FILE"
    else
        # No markers — migrate from legacy format. Strip the old un-marked
        # block (header comment + bare DOTFILES_ exports), collapse trailing
        # blank lines, then append the new marker-delimited block.
        if [[ -f "$CONFIG_FILE" ]]; then
            sed_inplace "$CONFIG_FILE" '/^export DOTFILES_/d'
            sed_inplace "$CONFIG_FILE" '/^# Dotfiles Configuration/d'

            local _tmp
            _tmp="$(mktemp "${CONFIG_FILE}.XXXXXX")" || _tmp=""
            if [[ -n "$_tmp" ]]; then
                awk '
                    /^[[:space:]]*$/ { blanks = blanks "\n"; next }
                    { if (NR > 1 && blanks != "") printf "\n"; print; blanks = "" }
                ' "$CONFIG_FILE" > "$_tmp" && mv "$_tmp" "$CONFIG_FILE"
            fi
        fi
        printf '\n%s\n' "$block" >> "$CONFIG_FILE"
    fi
}

# =============================================================================
# Environment Setup
# =============================================================================
setup_environment() {
    show_section "Configuration"

    # Load existing configuration and set defaults
    load_config
    set_defaults

    # Auto-detect repository
    if [[ -z "${DOTFILES_REPO:-}" ]]; then
        if [[ -d "$SCRIPT_DIR/.git" ]]; then
            DOTFILES_REPO=$(cd "$SCRIPT_DIR" && git remote get-url origin 2>/dev/null || echo "")
        else
            DOTFILES_REPO="$REPO_URL"
        fi
    fi
    export DOTFILES_REPO

    # Validate settings (show error but don't exit)
    validate_profile "$DOTFILES_PROFILE" || {
        _dotfiles_log_warning "Using default profile '$DEFAULT_PROFILE'"
        export DOTFILES_PROFILE="$DEFAULT_PROFILE"
    }

    # Verbose-only config summary
    if is_verbose; then
        _dotfiles_log_result "root   " "$DOTFILES_ROOT"
        _dotfiles_log_result "profile" "$DOTFILES_PROFILE"
        _dotfiles_log_result "verbose" "$DOTFILES_VERBOSE"
        _dotfiles_log_result "config " "$CONFIG_FILE"
    fi
}

# =============================================================================
# Repository Management
# =============================================================================
is_fresh_install() {
    [[ ! -d "$DOTFILES_ROOT/.git" ]]
}

clone_repository_if_missing() {
    # Only used during install. Update is a separate command (no git in install).
    if ! is_fresh_install; then
        return 0
    fi

    show_section "Repository Setup"
    _dotfiles_log_step "Cloning dotfiles repository"

    if [[ -z "$DOTFILES_REPO" ]]; then
        _dotfiles_log_error "Repository URL not specified"
        _dotfiles_log_hint "export DOTFILES_REPO=https://github.com/<you>/dotfiles.git"
        return 1
    fi
    _dotfiles_log_detail "Source: $DOTFILES_REPO"

    git clone "$DOTFILES_REPO" "$DOTFILES_ROOT" >/dev/null 2>&1 || {
        _dotfiles_log_error "Failed to clone $DOTFILES_REPO"
        _dotfiles_log_hint "check network reachability and credentials (try: git ls-remote \$DOTFILES_REPO)"
        return 1
    }
    cd "$DOTFILES_ROOT"
    local head_sha
    head_sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
    _dotfiles_log_detail "Repository cloned at $DOTFILES_ROOT (HEAD: $head_sha)"
}

# -----------------------------------------------------------------------------
# Update flow — git-only, safe stash/rebase/pop. Separate from install so that
# install never fails on a dirty working tree, and updates have a clear recovery
# path on conflict.
# -----------------------------------------------------------------------------
update_dotfiles() {
    local do_stash=false no_reload=false
    local _arg
    for _arg in "$@"; do
        [[ "$_arg" == "--stash" ]]     && do_stash=true
        [[ "$_arg" == "--no-reload" ]] && no_reload=true
    done

    if [[ ! -d "$DOTFILES_ROOT/.git" ]]; then
        _dotfiles_log_error "Not a git repository: $DOTFILES_ROOT"
        _dotfiles_log_hint "run: dotfiles install (to clone the repo first)"
        return 1
    fi
    cd "$DOTFILES_ROOT" || return 1

    # Pre-flight: abort if mid-rebase or mid-merge — user must resolve manually
    if [[ -d .git/rebase-merge || -d .git/rebase-apply ]]; then
        _dotfiles_log_error "Repository is mid-rebase. Resolve before updating."
        _dotfiles_log_dim "Use 'git rebase --continue' or 'git rebase --abort'"
        return 1
    fi
    if [[ -f .git/MERGE_HEAD ]]; then
        _dotfiles_log_error "Repository is mid-merge. Resolve before updating."
        _dotfiles_log_dim "Use 'git merge --abort' or commit the merge."
        return 1
    fi

    # Pre-flight: must be on a branch (not detached HEAD)
    local branch
    branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || {
        _dotfiles_log_error "Detached HEAD — checkout a branch before updating."
        return 1
    }
    local remote_branch="${DOTFILES_BRANCH:-$branch}"

    _dotfiles_log_step "Updating dotfiles (branch: $branch)"

    # Detect dirty state: tracked changes OR untracked files
    local was_dirty=false stash_ref=""
    if ! git diff --quiet HEAD 2>/dev/null || \
       [[ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ]]; then
        if ! $do_stash; then
            _dotfiles_log_error "Local changes detected. Resolve before updating, or pass --stash."
            _dotfiles_log_dim "Options:"
            _dotfiles_log_dim "  git stash && dotfiles update && git stash pop   # manual"
            _dotfiles_log_dim "  dotfiles update --stash                          # auto-stash + restore"
            _dotfiles_log_dim "  git commit -am 'WIP' && dotfiles update          # commit first"
            return 1
        fi
        was_dirty=true
        # `git stash create` returns commit SHA without touching refs
        stash_ref="$(git stash create -u 2>/dev/null)"
        if [[ -z "$stash_ref" ]]; then
            _dotfiles_log_error "Failed to create stash for local changes"
            return 1
        fi
        git stash store -m "dotfiles auto-stash $(date '+%Y-%m-%d %H:%M:%S')" "$stash_ref" >/dev/null 2>&1
        git reset --hard HEAD >/dev/null 2>&1
        git clean -fd >/dev/null 2>&1
        _dotfiles_log_detail "Local changes stashed (stash@{0})"
    fi

    # Pull with rebase — do NOT silence the error, let user see git's diagnostic
    if ! git pull --rebase origin "$remote_branch"; then
        git rebase --abort 2>/dev/null
        _dotfiles_log_error "Pull failed (see git output above)"
        if $was_dirty; then
            _dotfiles_log_warning "Your local changes are preserved in stash@{0}"
            _dotfiles_log_warning "Recovery: git stash list  →  git stash pop"
        fi
        return 1
    fi

    # Restore local changes if we stashed them
    if $was_dirty; then
        if ! git stash pop 2>/dev/null; then
            _dotfiles_log_warning "Conflicts while restoring local changes"
            _dotfiles_log_warning "Stashed changes remain in stash@{0}. Resolve with:"
            _dotfiles_log_dim "  git stash show -p stash@{0}    # preview"
            _dotfiles_log_dim "  git stash pop                  # retry (will conflict again)"
            _dotfiles_log_dim "  git checkout --theirs <file>   # take stash version"
            return 1
        fi
    fi

    _dotfiles_log_summary "Updated to $(git rev-parse --short HEAD)."

    $no_reload && return 0
    cd "${_ORIG_PWD:-$HOME}"
    # Skip the shell-replacement when the user passed --no-reload or when the
    # zsh wrapper function is in charge of the reload itself.
    if [[ "${DOTFILES_WRAPPER:-}" != "1" && "${DOTFILES_NO_RELOAD:-false}" != "true" ]]; then
        exec zsh
    fi
}

# -----------------------------------------------------------------------------
# Sync — update + reinstall in one go
# -----------------------------------------------------------------------------
sync_dotfiles() {
    update_dotfiles "${1:-}" --no-reload && install_dotfiles
}

# =============================================================================
# Symlink Management
# =============================================================================
readonly EXCLUDE_PATTERNS=(
    "README.md" "CLAUDE.md" "ARCHITECT.md" "Makefile"
    ".gitignore" "install" "bin" "config"
    "zsh" "docs" "zshenv" ".vscode" ".git" "*.zwc" "*.zwc.old"
    "tmux.conf"  # tmux config is linked conditionally — see _dotfiles_tmux_link_config
    "pwsh"       # pwsh tree never lands in $HOME on Unix
)

should_exclude() {
    local item="$1"
    for pattern in "${EXCLUDE_PATTERNS[@]}"; do
        # Use glob matching for patterns with wildcards, exact match otherwise
        if [[ "$pattern" == *"*"* ]]; then
            [[ "$item" == $pattern ]] && return 0
        else
            [[ "$item" == "$pattern" ]] && return 0
        fi
    done
    return 1
}

# Create a symlink with proper error handling
create_single_symlink() {
    local source_path="$1"
    local target_path="$2"
    local display_name="$3"

    # Remove existing symlink — refuse to rm -rf a real directory
    if [[ -L "$target_path" ]]; then
        rm -f "$target_path" || { _dotfiles_log_error "Failed to remove symlink: $target_path"; return 1; }
    elif [[ -e "$target_path" ]]; then
        _dotfiles_log_warning "Skipping $target_path — already exists and is not a symlink (remove manually if intended)"
        return 1
    fi

    # Create symlink (always do the work, only show output if verbose)
    if ln -sf "$source_path" "$target_path"; then
        is_verbose && _dotfiles_log_dim "${GREEN}${CHECK}${RESET} $display_name ${MAGENTA}${ARROW}${RESET} $target_path"
        return 0
    else
        _dotfiles_log_error "Failed to create symlink: $source_path -> $target_path"
        return 1
    fi
}

# Link files from source directory to target directory
link_directory_files() {
    local source_dir="$1"
    local target_prefix="$2"
    local subsection_title="$3"
    # 4th arg: "files" = link only regular files (skip directories).
    # Used for repo-root → $HOME so we don't symlink whole dirs like bin/,
    # zsh/, config/ into $HOME. Default (empty) accepts files AND dirs,
    # which is correct for config/* → ~/.config/* where dir-symlinks are
    # the intent (e.g. sheldon/ → ~/.config/sheldon/).
    local only_files="${4:-}"

    [[ ! -d "$source_dir" ]] && return 0

    show_subsection "$subsection_title"

    local linked_count=0
    local failed_count=0

    for item in "$source_dir"/*; do
        [[ ! -e "$item" ]] && continue  # Skip if item doesn't exist

        local name=$(basename "$item")
        local target="$target_prefix$name"

        # Caller-provided exclusions via DOTFILES_CONFIG_EXCLUDE (colon-delimited).
        if [[ -n "${DOTFILES_CONFIG_EXCLUDE:-}" ]] && \
           [[ ":${DOTFILES_CONFIG_EXCLUDE}:" == *":${name}:"* ]]; then
            continue
        fi

        # Files-only mode: skip directories entirely
        if [[ "$only_files" == "files" && -d "$item" ]]; then
            continue
        fi

        # Ensure target directory exists
        local target_dir
        target_dir=$(dirname "$target")
        [[ ! -d "$target_dir" ]] && mkdir -p "$target_dir"

        if ! should_exclude "$name" && [[ -f "$item" || -d "$item" ]]; then
            if create_single_symlink "$item" "$target" "$name"; then
                ((linked_count++))
            else
                ((failed_count++))
            fi
        fi
    done

    [[ $failed_count -gt 0 ]] && _dotfiles_log_warning "Failed to link $failed_count files"
}

# =============================================================================
# tmux setup — optional, machine-base. tmux is no longer in the core package
# set; it's installed only when the user opts in via:
#     dotfiles config set extra tmux
# (which lands in ~/.config/mise/conf.d/99-machine.toml). The functions below
# manage the *config + TPM* side of tmux and only fire when the binary is
# actually present, so the CLI is silent on machines that don't use tmux.
# =============================================================================

_dotfiles_tmux_link_config() {
    command -v tmux &>/dev/null || return 0
    [[ -f "$DOTFILES_ROOT/tmux.conf" ]] || return 0
    create_single_symlink "$DOTFILES_ROOT/tmux.conf" "$HOME/.tmux.conf" "tmux.conf"

    # Install TPM (tmux plugin manager) at a pinned tag. Plain git clone is
    # acceptable here — the repo is trusted and the tag is immutable.
    local tpm_dir="$HOME/.tmux/plugins/tpm"
    if [[ ! -d "$tpm_dir" ]] && command -v git &>/dev/null; then
        _dotfiles_log_info "Installing tmux plugin manager (v3.1.0)..."
        if git clone --depth=1 --branch v3.1.0 \
            https://github.com/tmux-plugins/tpm "$tpm_dir" >/dev/null 2>&1; then
            _dotfiles_log_success "TPM installed"
            local tpm_install_script="$tpm_dir/bindings/install_plugins"
            [[ -x "$tpm_install_script" ]] && "$tpm_install_script" &>/dev/null
        else
            _dotfiles_log_warning "TPM clone failed — install manually if needed"
        fi
    fi
}

_dotfiles_tmux_doctor() {
    command -v tmux &>/dev/null || return 0  # silent skip when tmux absent
    local ver conf_target
    ver="$(tmux -V 2>/dev/null)"
    _dotfiles_log_result "tmux" "${ver:-installed}"
    conf_target="$(readlink -f "$HOME/.tmux.conf" 2>/dev/null || true)"
    if [[ -f "$HOME/.tmux.conf" ]]; then
        _dotfiles_log_dim "config: ~/.tmux.conf${conf_target:+ -> $conf_target}"
    else
        _dotfiles_log_dim "config: ~/.tmux.conf missing — run: dotfiles link"
    fi
    [[ -d "$HOME/.tmux/plugins/tpm" ]] \
        && _dotfiles_log_dim "TPM: ~/.tmux/plugins/tpm" \
        || _dotfiles_log_dim "TPM: not installed"
}

_dotfiles_tmux_uninstall() {
    # Always run — symlink + TPM should be removed even if the tmux binary
    # has already been uninstalled by mise.
    local conf="$HOME/.tmux.conf"
    if [[ -L "$conf" ]]; then
        local target
        target="$(readlink "$conf" 2>/dev/null || true)"
        [[ "$target" == "${DOTFILES_ROOT:-$HOME/.dotfiles}"* ]] && rm -f "$conf" 2>/dev/null
    fi
    rm -rf "$HOME/.tmux/plugins" 2>/dev/null
}

create_symlinks() {
    _dotfiles_log_step "Creating symlinks..."
    show_section "Symlinks"

    # Link dotfiles — files only, never directories. Folders like bin/,
    # zsh/, config/, .git/ stay inside the repo; only .zshrc / .tmux.conf /
    # .p10k.zsh style file dotfiles land in $HOME.
    link_directory_files "$DOTFILES_ROOT" "$HOME/." "Linking dotfiles..." "files"

    # Link config files. Two packages need special-case file-level symlinks
    # instead of the default directory-symlink:
    #   - claude → ~/.claude/* (different target dir)
    #   - mise   → must NOT dir-symlink ~/.config/mise/, because mise writes
    #              its own ~/.config/mise/config.toml on every `mise use -g`
    #              and we don't want that file synced into the repo. Only the
    #              shared shards under config/mise/conf.d/*.toml get linked.
    mkdir -p "$HOME/.config"
    DOTFILES_CONFIG_EXCLUDE="claude:mise" \
        link_directory_files "$DOTFILES_ROOT/config" "$HOME/.config/" "Linking config files..."

    # Link Claude Code config files individually into ~/.claude/
    if [[ -d "$DOTFILES_ROOT/config/claude" ]]; then
        mkdir -p "$HOME/.claude"
        link_directory_files "$DOTFILES_ROOT/config/claude" "$HOME/.claude/" "Linking Claude Code config..."
    fi

    # One-time migration: older installs dir-symlinked the whole ~/.config/mise
    # to the repo. The new layout needs it to be a real dir with per-file shard
    # symlinks inside, so detect the legacy link and replace it. Only remove if
    # it points at THIS repo — never touch a foreign symlink.
    if [[ -L "$HOME/.config/mise" ]]; then
        _mise_link_target="$(readlink "$HOME/.config/mise" 2>/dev/null || true)"
        if [[ "$_mise_link_target" == "$DOTFILES_ROOT/config/mise" ]]; then
            rm -f "$HOME/.config/mise"
            _dotfiles_log_step "Migrated: replaced legacy ~/.config/mise dir-symlink with real dir"
        fi
        unset _mise_link_target
    fi

    # Link mise shared shards file-by-file into ~/.config/mise/conf.d/. The
    # set of shards we link depends on the active profile (strict superset):
    #   core    → no shards (sheldon + mise only)
    #   server  → 00-server.toml
    #   develop → 00-server.toml + 10-develop.toml
    # ~/.config/mise/config.toml is left as a real machine-local file — that's
    # where `mise use -g` writes go. Pre-create it as a placeholder; without
    # it, mise falls back to writing into the alphabetically-first conf.d file
    # (which IS a symlink to the repo) and silently leaks per-machine
    # declarations into the synced manifest.
    if [[ -d "$DOTFILES_ROOT/config/mise/conf.d" ]]; then
        mkdir -p "$HOME/.config/mise/conf.d"

        # 1. Remove any stale repo-targeted symlinks so switching profiles
        #    (or repo renames like 00-common.toml → 00-server.toml) doesn't
        #    leave dangling links pointing at vanished files.
        local _l _t
        for _l in "$HOME/.config/mise/conf.d"/*.toml; do
            [[ -e "$_l" || -L "$_l" ]] || continue   # bash no-match guard
            [[ -L "$_l" ]] || continue
            _t="$(readlink "$_l" 2>/dev/null || true)"
            [[ "$_t" == "$DOTFILES_ROOT/config/mise/conf.d/"* ]] && rm -f "$_l"
        done

        # 2. Determine which shards the active profile wants.
        local -a _wanted_shards=()
        case "${DOTFILES_PROFILE:-core}" in
            server)              _wanted_shards=("00-server.toml") ;;
            full|dev|develop)    _wanted_shards=("00-server.toml" "10-develop.toml") ;;
            *)                   _wanted_shards=() ;;  # core or unknown: link none
        esac

        # 3. Link only the shards that exist in the repo and match the profile.
        # Guard the expansion: bash 3.2 (macOS /bin/bash) errors on
        # "${empty_array[@]}" under `set -u`, which would crash install/link
        # for the `core` profile (no shards). Same pattern as parse_args.
        if (( ${#_wanted_shards[@]} > 0 )); then
            local _s _src
            for _s in "${_wanted_shards[@]}"; do
                _src="$DOTFILES_ROOT/config/mise/conf.d/$_s"
                [[ -f "$_src" ]] || continue
                create_single_symlink "$_src" "$HOME/.config/mise/conf.d/$_s" "$_s"
            done
        fi
    fi
    if [[ ! -e "$HOME/.config/mise/config.toml" ]]; then
        mkdir -p "$HOME/.config/mise"
        cat > "$HOME/.config/mise/config.toml" <<'EOF'
# Machine-local mise config — NOT synced via dotfiles.
# Written by `mise use -g <tool>` and similar interactive commands.
# Shared declarations live in ~/.config/mise/conf.d/*.toml (symlinks to the repo).
EOF
    fi

    # tmux config + TPM — only when tmux is installed on this machine.
    _dotfiles_tmux_link_config
}

# Check symlinks in a directory
check_directory_symlinks() {
    local source_dir="$1"
    local target_prefix="$2"
    local subsection_title="$3"
    local total_links_ref="$4"
    local broken_links_ref="$5"

    [[ ! -d "$source_dir" ]] && return 0

    show_subsection "$subsection_title"

    local item_count=0

    for item in "$source_dir"/*; do
        [[ ! -e "$item" ]] && continue

        local name=$(basename "$item")
        local target="$target_prefix$name"

        # Honor caller-provided ":"-separated exclusion list
        if [[ -n "${DOTFILES_CONFIG_EXCLUDE:-}" ]] && [[ ":${DOTFILES_CONFIG_EXCLUDE}:" == *":${name}:"* ]]; then
            continue
        fi

        if ! should_exclude "$name" && [[ -f "$item" || -d "$item" ]]; then
            ((item_count++))
            if [[ -L "$target" ]] && [[ -e "$target" ]]; then
                is_verbose && _dotfiles_log_dim "${GREEN}${CHECK}${RESET} $name ${MAGENTA}${ARROW}${RESET} $target"
                printf -v "$total_links_ref" '%d' "$((${!total_links_ref} + 1))"
            else
                _dotfiles_log_error "Broken or missing: $target"
                printf -v "$broken_links_ref" '%d' "$((${!broken_links_ref} + 1))"
            fi
        fi
    done

    _dotfiles_log_debug "Checked $item_count items in $source_dir"
}

verify_symlinks() {
    # Always show progress, detailed section only in verbose mode
    _dotfiles_log_step "Verifying symlinks..."
    show_section "Verifying symlinks..."

    [[ -n "$DOTFILES_ROOT" ]] || {
        _dotfiles_log_error "DOTFILES_ROOT is not set"
        _dotfiles_log_hint "run: dotfiles config set root <path>  (or export DOTFILES_ROOT)"
        return 1
    }
    [[ -d "$DOTFILES_ROOT" ]] || {
        _dotfiles_log_error "Dotfiles directory not found: $DOTFILES_ROOT"
        _dotfiles_log_hint "run: dotfiles install  (to clone the repo)"
        return 1
    }

    local total_links=0
    local broken_links=0

    # Check dotfiles symlinks
    check_directory_symlinks "$DOTFILES_ROOT" "$HOME/." "Checking dotfiles symlinks..." total_links broken_links

    # Check config files symlinks (skip 'claude' and 'mise' — both checked
    # separately below because they use file-level symlinks, not dir-level)
    DOTFILES_CONFIG_EXCLUDE="claude:mise" \
        check_directory_symlinks "$DOTFILES_ROOT/config" "$HOME/.config/" "Checking config files symlinks..." total_links broken_links

    # Check Claude Code config symlinks (~/.claude/)
    [[ -d "$DOTFILES_ROOT/config/claude" ]] && \
        check_directory_symlinks "$DOTFILES_ROOT/config/claude" "$HOME/.claude/" "Checking Claude Code config symlinks..." total_links broken_links

    # Check mise conf.d shards (~/.config/mise/conf.d/)
    [[ -d "$DOTFILES_ROOT/config/mise/conf.d" ]] && \
        check_directory_symlinks "$DOTFILES_ROOT/config/mise/conf.d" "$HOME/.config/mise/conf.d/" "Checking mise conf.d shards..." total_links broken_links

    # Summary (always show)
    echo
    if [[ $broken_links -eq 0 ]]; then
        _dotfiles_log_success "All $total_links symlinks are working"
        return 0
    else
        _dotfiles_log_warning "Found $broken_links broken symlinks out of $total_links total"
        return 1
    fi
}

# Check which packages in the active profile are not installed
verify_packages() {
    _dotfiles_log_step "Checking package status for profile: $DOTFILES_PROFILE"
    show_section "Package Status"

    command -v zsh &>/dev/null || {
        _dotfiles_log_warning "zsh not found, cannot check packages"
        return 0
    }

    # Run packages with VERBOSE=false; init_package_template prints a warning
    # line to stderr for each not-installed package: "[dotfiles] X not installed"
    local warnings
    warnings=$(
        DOTFILES_VERBOSE=false \
        DOTFILES_PROFILE="$DOTFILES_PROFILE" \
        DOTFILES_ROOT="$DOTFILES_ROOT" \
        zsh -c '
            setopt NULL_GLOB
            [[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$PATH:$HOME/.local/bin"
            source "$DOTFILES_ROOT/zsh/lib/platform.zsh"
            source "$DOTFILES_ROOT/zsh/lib/installer.zsh"

            typeset -a pkg_dirs
            pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core")
            [[ "$DOTFILES_PROFILE" != "core" \
               && -d "$DOTFILES_ROOT/zsh/packages/$DOTFILES_PROFILE" ]] && \
                pkg_dirs+=("$DOTFILES_ROOT/zsh/packages/$DOTFILES_PROFILE")

            for pkg_dir in "$pkg_dirs[@]"; do
                [[ -d "$pkg_dir" ]] || continue
                for pkg_file in "$pkg_dir"/*.zsh(N); do
                    source "$pkg_file"
                done
            done
        ' 2>&1 | grep '^\[dotfiles\]'
    )

    echo
    if [[ -z "$warnings" ]]; then
        _dotfiles_log_success "All packages for profile '$DOTFILES_PROFILE' are installed"
        return 0
    else
        _dotfiles_log_warning "Not installed packages:"
        while IFS= read -r line; do
            echo -e "  ${YELLOW}${BULLET}${RESET} $line"
        done <<< "$warnings"
        echo
        _dotfiles_log_info "Run 'dotfiles install' to install missing packages"
        return 1
    fi
}

# Combined verify: symlinks + packages
verify_all() {
    local sym_rc=0 pkg_rc=0
    verify_symlinks || sym_rc=$?
    echo
    verify_packages || pkg_rc=$?
    [[ $sym_rc -eq 0 && $pkg_rc -eq 0 ]]
}

# =============================================================================
# Package Installation
# =============================================================================
install_packages() {
    # Always show progress, detailed section only in verbose mode
    _dotfiles_log_step "Installing packages for profile: $DOTFILES_PROFILE"
    show_section "Package Installation"

    command -v zsh &>/dev/null || {
        _dotfiles_log_warning "zsh not found, skipping package installation"
        return 0
    }

    echo
    _dotfiles_log_info "Checking packages for profile: $DOTFILES_PROFILE"
    echo

    # Package files use zsh-specific syntax (typeset, setopt, glob qualifiers).
    # Must run in a zsh subprocess — bash cannot source them correctly.
    # DOTFILES_VERBOSE is forced true here so package lifecycle output is visible
    # during install. The user's saved DOTFILES_VERBOSE only affects normal shell startup.
    local exit_code=0
    DOTFILES_INSTALL=true \
    DOTFILES_VERBOSE=true \
    DOTFILES_PROFILE="$DOTFILES_PROFILE" \
    DOTFILES_ROOT="$DOTFILES_ROOT" \
    zsh -c '
        setopt NULL_GLOB
        [[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$PATH:$HOME/.local/bin"
        source "$DOTFILES_ROOT/zsh/lib/platform.zsh"
        source "$DOTFILES_ROOT/zsh/lib/installer.zsh"

        typeset -a pkg_dirs
        pkg_dirs=("$DOTFILES_ROOT/zsh/packages/core")
        [[ "$DOTFILES_PROFILE" != "core" && "$DOTFILES_PROFILE" != "minimal" \
           && -d "$DOTFILES_ROOT/zsh/packages/$DOTFILES_PROFILE" ]] && \
            pkg_dirs+=("$DOTFILES_ROOT/zsh/packages/$DOTFILES_PROFILE")

        for pkg_dir in "$pkg_dirs[@]"; do
            [[ -d "$pkg_dir" ]] || continue
            for pkg_file in "$pkg_dir"/*.zsh(N); do
                source "$pkg_file"
            done
        done
    ' || exit_code=$?

    [[ $exit_code -ne 0 ]] && _dotfiles_log_error "Package installation encountered errors (exit $exit_code)"

    echo
    _dotfiles_log_success "Package check and installation completed"

    # Show profile-specific package list — derived from filesystem so adding
    # or removing a package file requires no edits here.
    echo
    _dotfiles_log_info "Profile '$DOTFILES_PROFILE' includes:"
    local _dir _file _name _names
    while IFS= read -r _dir; do
        _names=""
        for _file in "$_dir"/*.zsh; do
            [[ -f "$_file" ]] || continue
            _name="$(basename "$_file" .zsh)"
            _names+="${_names:+, }$_name"
        done
        [[ -n "$_names" ]] && echo -e "  ${CYAN}${BULLET}${RESET} $(basename "$_dir"): $_names"
    done < <(dotfiles_profile_dirs "$DOTFILES_PROFILE")
}

# =============================================================================
# Profile Management
# =============================================================================
configure_profile() {
    _dotfiles_log_info "Configuring profile: $DOTFILES_PROFILE"
    save_config
    _dotfiles_log_success "Profile configured successfully"
}

# =============================================================================
# `dotfiles config` — get/set/list/edit/path/keys for ~/.zshenv
# =============================================================================
# Single source of truth for valid keys (kept tiny on purpose).
readonly CONFIG_KEYS=(profile verbose root exclude extra)

config_show_usage() {
    cat <<EOF
USAGE:
  dotfiles config                    List current configuration
  dotfiles config get <key>          Print raw value of <key> to stdout
  dotfiles config set <key> <value>  Validate and save <key>=<value>
  dotfiles config edit               Open \$EDITOR on the config file
  dotfiles config path               Print config file path
  dotfiles config keys               List valid keys (one per line)

KEYS:
  profile   core | server | develop
  verbose   true | false
  exclude   comma-separated tools to drop from the active profile
  extra     comma-separated tools to add on top of the active profile
  root      absolute path to dotfiles repo

EXAMPLES:
  dotfiles config set verbose true
  dotfiles config set profile develop
  dotfiles config set exclude eza,bat       # skip these on this machine
  dotfiles config set extra htop,starship   # add these on this machine
  dotfiles config set extra tmux            # opt-in tmux on this machine
  dotfiles config get profile               # prints to stdout (machine-readable)
  dotfiles config edit                      # open managed block in \$EDITOR
EOF
}

# Read a config value strictly from the saved file (ignores any env override).
# `extract_config_value` lets env win — that's correct for runtime behavior
# but wrong for `config get`, where the user wants to know what's persisted.
_config_read_file() {
    local var_name="$1"
    [[ -f "$CONFIG_FILE" ]] || return 0

    local line value
    line=$(grep "^export ${var_name}=" "$CONFIG_FILE" 2>/dev/null | tail -1 || echo "")
    [[ -z "$line" ]] && return 0

    value="${line#*=}"
    while [[ "${value:0:1}" == '"' || "${value:0:1}" == "'" ]]; do value="${value:1}"; done
    while [[ "${value: -1:1}" == '"' || "${value: -1:1}" == "'" ]]; do value="${value%?}"; done

    # Resolve ${VAR:-default} → default (we want the SAVED value, not env)
    if [[ "$value" == '${'"$var_name"':-'*'}' ]]; then
        value="${value#'${'"$var_name"':-'}"
        value="${value%'}'}"
    fi
    printf '%s\n' "$value"
}

# Map config key → (var_name, default). Used by config_get and config_list.
_config_key_lookup() {
    case "$1" in
        profile) printf '%s\n%s\n' "DOTFILES_PROFILE" "$DEFAULT_PROFILE" ;;
        verbose) printf '%s\n%s\n' "DOTFILES_VERBOSE" "$DEFAULT_VERBOSE" ;;
        root)    printf '%s\n%s\n' "DOTFILES_ROOT"    "$DEFAULT_ROOT" ;;
        exclude) printf '%s\n%s\n' "DOTFILES_EXCLUDE" "$DEFAULT_EXCLUDE" ;;
        extra)   printf '%s\n%s\n' "DOTFILES_EXTRA"   "$DEFAULT_EXTRA" ;;
        *)       return 1 ;;
    esac
}

# Resolve a key's saved value: file → default fallback.
_config_saved_value() {
    local lookup
    lookup="$(_config_key_lookup "$1")" || return 1
    local var_name="${lookup%%$'\n'*}"
    # Command substitution strips trailing newlines — if the default is "",
    # the substring after the first newline collapses, so $lookup ends up
    # without a separator. Guard explicitly so default stays empty.
    local default=""
    [[ "$lookup" == *$'\n'* ]] && default="${lookup#*$'\n'}"
    local value
    value="$(_config_read_file "$var_name")"
    [[ -z "$value" ]] && value="$default"
    printf '%s\n' "$value"
}

config_list() {
    if [[ "${DOTFILES_OUTPUT_FORMAT:-}" == "json" ]]; then
        local v
        v="$(_config_saved_value verbose)"
        printf '{"profile":"%s","verbose":%s,"root":"%s","exclude":"%s","extra":"%s","file":"%s"}\n' \
            "$(_config_saved_value profile)" \
            "${v:-false}" \
            "$(_config_saved_value root)" \
            "$(_config_saved_value exclude)" \
            "$(_config_saved_value extra)" \
            "$CONFIG_FILE"
        return 0
    fi
    show_section "Configuration"
    _dotfiles_table \
        "profile" "$(_config_saved_value profile)" \
        "verbose" "$(_config_saved_value verbose)" \
        "exclude" "$(_config_saved_value exclude)" \
        "extra"   "$(_config_saved_value extra)" \
        "root"    "$(_config_saved_value root)" \
        "file"    "$CONFIG_FILE"
}

config_get() {
    local key="${1:-}"
    case "$key" in
        "")
            _dotfiles_log_error "Key required (one of: ${CONFIG_KEYS[*]})"
            _dotfiles_log_hint "example: dotfiles config get profile"
            return 1 ;;
        profile|verbose|root|exclude|extra) _config_saved_value "$key" ;;
        *)
            _dotfiles_log_error "Unknown key: $key (valid: ${CONFIG_KEYS[*]})"
            local _sug
            _sug="$(_dotfiles_did_you_mean "$key" "${CONFIG_KEYS[@]}" 2>/dev/null)"
            [[ -n "$_sug" ]] && _dotfiles_log_hint "did you mean: $_sug?"
            return 1 ;;
    esac
}

config_set() {
    local key="${1:-}" value="${2:-}"
    [[ -z "$key" ]] && {
        _dotfiles_log_error "Usage: dotfiles config set <key> <value>"
        return 1
    }
    # Allow empty value only for exclude/extra (means "clear the override").
    # Other keys reject empty because they'd leave the user in an invalid state.
    if [[ -z "$value" && "$key" != "exclude" && "$key" != "extra" ]]; then
        _dotfiles_log_error "Empty value not allowed for '$key' (use 'exclude' or 'extra' to clear overrides)"
        return 1
    fi
    case "$key" in
        profile)
            validate_profile "$value" || return 1
            export DOTFILES_PROFILE="$value"
            ;;
        verbose)
            case "$value" in
                true|false) export DOTFILES_VERBOSE="$value" ;;
                *) _dotfiles_log_error "verbose must be 'true' or 'false' (got: $value)"
                   return 1 ;;
            esac
            ;;
        root)
            [[ -d "$value" ]] || {
                _dotfiles_log_error "root must be an existing directory (got: $value)"
                return 1
            }
            # Resolve to absolute path
            value="$(cd "$value" && pwd -P)"
            export DOTFILES_ROOT="$value"
            ;;
        exclude|extra)
            # Comma-separated tool names. Allow empty (clears the override).
            # Normalize whitespace inside comma-list so "eza, bat" → "eza,bat".
            local _normalized
            _normalized="$(printf '%s' "$value" | tr -d '[:space:]')"
            if [[ "$key" == "exclude" ]]; then
                export DOTFILES_EXCLUDE="$_normalized"
            else
                export DOTFILES_EXTRA="$_normalized"
            fi
            value="$_normalized"   # so the summary line shows what was saved
            ;;
        *)
            _dotfiles_log_error "Unknown key: $key (valid: ${CONFIG_KEYS[*]})"
            local _sug
            _sug="$(_dotfiles_did_you_mean "$key" "${CONFIG_KEYS[@]}" 2>/dev/null)"
            [[ -n "$_sug" ]] && _dotfiles_log_hint "did you mean: $_sug?"
            return 1
            ;;
    esac
    save_config
    # tier-1 helper: CLI command feedback must show even when verbose is off
    # (e.g. when the user is turning verbose itself off).
    _dotfiles_log_summary "$key = $value"
}

config_command() {
    local action="${1:-list}"
    [[ $# -gt 0 ]] && shift
    case "$action" in
        ""|list)        config_list ;;
        get)            config_get "${1:-}" ;;
        set)            config_set "${1:-}" "${2:-}" ;;
        edit)           "${EDITOR:-vi}" "$CONFIG_FILE" ;;
        path)           printf '%s\n' "$CONFIG_FILE" ;;
        keys)           printf '%s\n' "${CONFIG_KEYS[@]}" ;;
        -h|--help|help) config_show_usage ;;
        *)
            _dotfiles_log_error "Unknown config action: $action"
            echo
            config_show_usage
            return 1
            ;;
    esac
}

# =============================================================================
# `dotfiles status` — fast read-only snapshot ("where am I right now")
# =============================================================================
# Counts symlinks pointing into DOTFILES_ROOT under the standard target dirs.
# Echoes "<total> <broken>" so the caller can read both with a single command.
_status_count_symlinks() {
    local total=0 broken=0 link target
    local -a scan_dirs=("$HOME" "$HOME/.config" "$HOME/.claude" "$HOME/.config/mise/conf.d")
    local dir
    for dir in "${scan_dirs[@]}"; do
        [[ -d "$dir" ]] || continue
        while IFS= read -r link; do
            target="$(readlink "$link" 2>/dev/null)" || continue
            [[ "$target" == "$DOTFILES_ROOT"* ]] || continue
            ((total++))
            [[ -e "$link" ]] || ((broken++))
        done < <(find "$dir" -mindepth 1 -maxdepth 2 -type l 2>/dev/null)
    done
    printf '%d %d\n' "$total" "$broken"
}

# Machine-readable status. Emits a single-line JSON object (no jq required).
# Boolean and numeric fields are unquoted. String fields use the small set of
# values we control (no shell metacharacters, no embedded quotes/newlines).
status_command_json() {
    local profile verbose root branch head_sha dirty upstream ahead behind
    local sym sym_total sym_broken pkg_total _dir

    profile="$(_config_saved_value profile)"
    verbose="$(_config_saved_value verbose)"; verbose="${verbose:-false}"
    root="$(_config_saved_value root)"

    branch=""; head_sha=""; upstream=""; ahead=0; behind=0; dirty=0
    if [[ -d "$DOTFILES_ROOT/.git" ]]; then
        branch="$(git -C "$DOTFILES_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo detached)"
        head_sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo "")"
        dirty="$(git -C "$DOTFILES_ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
        upstream="$(git -C "$DOTFILES_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")"
        if [[ -n "$upstream" ]]; then
            ahead="$(git -C "$DOTFILES_ROOT" rev-list --count "@{u}..HEAD" 2>/dev/null || echo 0)"
            behind="$(git -C "$DOTFILES_ROOT" rev-list --count "HEAD..@{u}" 2>/dev/null || echo 0)"
        fi
    fi

    sym="$(_status_count_symlinks)"
    sym_total="${sym% *}"
    sym_broken="${sym#* }"

    pkg_total=0
    while IFS= read -r _dir; do
        pkg_total=$((pkg_total + $(find "$_dir" -name "*.zsh" 2>/dev/null | wc -l)))
    done < <(dotfiles_profile_dirs "$profile")

    printf '{"profile":"%s","verbose":%s,"root":"%s","git":{"branch":"%s","head":"%s","upstream":"%s","ahead":%d,"behind":%d,"dirty":%d},"symlinks":{"active":%d,"broken":%d},"packages":{"declared":%d}}\n' \
        "$profile" "$verbose" "$root" \
        "$branch" "$head_sha" "$upstream" "$ahead" "$behind" "$dirty" \
        "$sym_total" "$sym_broken" "$pkg_total"
}

status_command() {
    if [[ "${DOTFILES_OUTPUT_FORMAT:-}" == "json" ]]; then
        status_command_json
        return $?
    fi
    show_section "Status"

    # ---- Identity ----
    _dotfiles_table \
        "profile" "$(_config_saved_value profile)" \
        "verbose" "$(_config_saved_value verbose)" \
        "root"    "$(_config_saved_value root)"

    # ---- Git state ----
    if [[ -d "$DOTFILES_ROOT/.git" ]]; then
        echo
        local branch head_sha ahead behind dirty upstream
        branch="$(git -C "$DOTFILES_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo 'detached')"
        head_sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo '?')"
        dirty="$(git -C "$DOTFILES_ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
        upstream="$(git -C "$DOTFILES_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo '')"

        local remote_val dirty_val
        if [[ -n "$upstream" ]]; then
            ahead="$(git -C "$DOTFILES_ROOT" rev-list --count "@{u}..HEAD" 2>/dev/null || echo '?')"
            behind="$(git -C "$DOTFILES_ROOT" rev-list --count "HEAD..@{u}" 2>/dev/null || echo '?')"
            remote_val="$upstream  ↑${ahead}  ↓${behind}"
        else
            remote_val="(no upstream)"
        fi
        [[ "$dirty" == "0" ]] && dirty_val="clean" || dirty_val="$dirty file(s) modified"

        _dotfiles_table \
            "branch" "$branch ($head_sha)" \
            "remote" "$remote_val" \
            "dirty"  "$dirty_val"
    fi

    # ---- Symlinks + packages ----
    echo
    local sym_counts total broken
    sym_counts="$(_status_count_symlinks)"
    total="${sym_counts% *}"
    broken="${sym_counts#* }"

    local sym_val
    if [[ "$broken" == "0" ]]; then
        sym_val="$total active, 0 broken"
    else
        sym_val="$total active, ${broken} broken (run: dotfiles clean)"
    fi

    local pkg_total=0 _dir
    while IFS= read -r _dir; do
        pkg_total=$((pkg_total + $(find "$_dir" -name "*.zsh" 2>/dev/null | wc -l)))
    done < <(dotfiles_profile_dirs "$DOTFILES_PROFILE")

    _dotfiles_table \
        "symlinks" "$sym_val" \
        "packages" "$pkg_total declared (run: dotfiles doctor)"
}

# =============================================================================
# Main Installation Flow
# =============================================================================
# =============================================================================
# Install flow — TWO modes only.
#
#   curl     One-liner bootstrap on a clean machine: `curl ...|bash`. Detected
#            by absence of $DOTFILES_ROOT/.git AND non-TTY stdin (the pipe).
#            Auto-pilot. Never `exec zsh` (would land in a broken state inside
#            the curl-piped non-interactive bash).
#   local    Everything else — running the script on a checked-out repo, with
#            or without prior install. Compact colored header + footer. May
#            `exec zsh` per existing rules.
#
# Color is used freely here: blue for the title bar, cyan for section
# headers, green for ✓ markers, magenta for accents, gray for descriptions.
# =============================================================================

# Centered title bar — bold blue rule with subtitle in the middle.
# Used by both modes.
_install_titlebar() {
    local subtitle="$1"
    local cols=72 left="DOTFILES(1)" right="DOTFILES(1)"
    local pad_l=$(( (cols - ${#left} - ${#subtitle} - ${#right}) / 2 ))
    (( pad_l < 1 )) && pad_l=1
    local pad_r=$(( cols - ${#left} - pad_l - ${#subtitle} - ${#right} ))
    (( pad_r < 1 )) && pad_r=1
    printf '%b%s%*s%b%s%b%*s%s%b\n' \
        "$BOLD$BLUE" "$left" "$pad_l" "" \
        "$BOLD$WHITE" "$subtitle" "$BOLD$BLUE" \
        "$pad_r" "" "$right" "$RESET"
    echo
}

# Print a man-page section header in bold cyan.
_install_section() {
    printf '%b%s%b\n' "$BOLD$CYAN" "$1" "$RESET"
}

# Welcome screen — one render at the top of every install run.
# Args: <mode>  "curl" | "local"
_install_welcome() {
    local mode="$1"
    local profile pkg_total _dir target=${DOTFILES_ROOT/#$HOME/~}
    profile="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    pkg_total=0
    while IFS= read -r _dir; do
        pkg_total=$((pkg_total + $(find "$_dir" -name "*.zsh" 2>/dev/null | wc -l)))
    done < <(dotfiles_profile_dirs "$profile" 2>/dev/null)

    if [[ "$mode" == "curl" ]]; then
        clear 2>/dev/null
        _install_titlebar "Installing"
        _install_section "PLAN"
        printf '    %bsource%b   %s\n'           "$GRAY" "$RESET" "${DOTFILES_REPO:-$REPO_URL}"
        printf '    %btarget%b   %b%s%b\n'       "$GRAY" "$RESET" "$BOLD$WHITE" "$target" "$RESET"
        printf '    %bprofile%b  %b%s%b  %b(%d packages)%b\n' \
            "$GRAY" "$RESET" "$BOLD$YELLOW" "$profile" "$RESET" "$DIM" "$pkg_total" "$RESET"
        printf '    %bconfig%b   %b%s%b  %b(managed block)%b\n' \
            "$GRAY" "$RESET" "$WHITE" "${CONFIG_FILE/#$HOME/~}" "$RESET" "$DIM" "$RESET"
        echo
        _install_section "SAFE BY DEFAULT"
        printf '    %b•%b Existing files are %bnot deleted%b — only repo-pointing symlinks are touched.\n' \
            "$MAGENTA" "$RESET" "$BOLD" "$RESET"
        printf '    %b•%b %s is backed up before edit.\n' \
            "$MAGENTA" "$RESET" "${CONFIG_FILE/#$HOME/~}"
        printf '    %b•%b Reverse anytime with %bdotfiles uninstall%b.\n' \
            "$MAGENTA" "$RESET" "$BOLD$WHITE" "$RESET"
        echo
        printf '%bcurl mode — non-interactive. Proceeding automatically.%b\n' "$DIM" "$RESET"
        echo
        sleep 1
    else
        local sha=""
        is_fresh_install || sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo '?')"
        echo
        if [[ -n "$sha" ]]; then
            printf '%b▸%b %brefreshing dotfiles%b · profile %b%s%b · HEAD %b%s%b\n' \
                "$BOLD$MAGENTA" "$RESET" \
                "$BOLD$WHITE" "$RESET" \
                "$BOLD$YELLOW" "$profile" "$RESET" \
                "$DIM" "$sha" "$RESET"
        else
            printf '%b▸%b %binstalling dotfiles%b · profile %b%s%b · target %b%s%b\n' \
                "$BOLD$MAGENTA" "$RESET" \
                "$BOLD$WHITE" "$RESET" \
                "$BOLD$YELLOW" "$profile" "$RESET" \
                "$BOLD$WHITE" "$target" "$RESET"
        fi
        echo
    fi
}

# Closing screen.
# Args: <mode>  "curl" | "local"
_install_done() {
    local mode="$1"
    local sha
    sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo unknown)"

    if [[ "$mode" == "curl" ]]; then
        echo
        _install_titlebar "Installed"
        _install_section "WHAT HAPPENED"
        printf '    %b✓%b cloned       %b%s%b @ %b%s%b\n' \
            "$GREEN" "$RESET" "$BOLD$WHITE" "${DOTFILES_ROOT/#$HOME/~}" "$RESET" "$DIM" "$sha" "$RESET"
        printf '    %b✓%b symlinked    configs into %b~/%b · %b~/.config%b · %b~/.claude%b\n' \
            "$GREEN" "$RESET" "$WHITE" "$RESET" "$WHITE" "$RESET" "$WHITE" "$RESET"
        printf '    %b✓%b packages     profile %b%s%b ready\n' \
            "$GREEN" "$RESET" "$BOLD$YELLOW" "$DOTFILES_PROFILE" "$RESET"
        printf '    %b✓%b config       managed block written to %b%s%b\n' \
            "$GREEN" "$RESET" "$WHITE" "${CONFIG_FILE/#$HOME/~}" "$RESET"
        echo
        _install_section "NEXT STEPS"
        printf '    %b1.%b Open a new terminal, or run:  %bexec zsh%b\n'   "$BOLD$MAGENTA" "$RESET" "$BOLD$GREEN" "$RESET"
        printf '    %b2.%b Verify install:               %bdotfiles doctor%b\n' "$BOLD$MAGENTA" "$RESET" "$BOLD$CYAN" "$RESET"
        printf '    %b3.%b Browse the menu:              %bdotfiles%b\n'         "$BOLD$MAGENTA" "$RESET" "$BOLD$CYAN" "$RESET"
        echo
        printf '    %bSource:%b %s\n' "$GRAY" "$RESET" "$REPO_URL"
        echo
    else
        echo
        printf '%b✓%b dotfiles ready · profile %b%s%b · HEAD %b%s%b · run %bdotfiles status%b for details\n' \
            "$BOLD$GREEN" "$RESET" \
            "$BOLD$YELLOW" "$DOTFILES_PROFILE" "$RESET" \
            "$DIM" "$sha" "$RESET" \
            "$BOLD$CYAN" "$RESET"
        echo
    fi
}

# Decide whether to `exec zsh`. curl-mode never reloads.
_install_handle_reload() {
    local mode="$1"
    cd "${_ORIG_PWD:-$HOME}" 2>/dev/null || true

    [[ "$mode" == "curl" ]] && return 0
    [[ "${DOTFILES_NO_RELOAD:-false}" == "true" || "${DOTFILES_WRAPPER:-}" == "1" ]] && return 0

    if ! command -v zsh >/dev/null 2>&1; then
        _dotfiles_log_warning "zsh not found — install zsh and restart your terminal"
        return 0
    fi
    exec zsh
}

# Interactive install menu (UC-18) — pick profile + overrides when the user
# pasted the install one-liner without flags. Uses </dev/tty so it works
# under `curl … | bash` where stdin is the pipe. Returns 1 if the user
# cancels, 0 otherwise (after setting + persisting the chosen values).
_install_interactive_menu() {
    # Available profiles from the filesystem (filtered to non-empty + core).
    local -a profiles
    profiles=()
    local _p
    for _p in $(list_valid_profiles); do profiles+=("$_p"); done
    local default_profile="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    local default_exclude="${DOTFILES_EXCLUDE:-}"
    local default_extra="${DOTFILES_EXTRA:-}"

    {
        printf '\n%bDOTFILES SETUP%b — pick what to install\n\n' "$BOLD$CYAN" "$RESET"
        printf '  %bProfile%b   (current: %s)\n' "$BOLD" "$RESET" "$default_profile"
        local _i=1
        for _p in "${profiles[@]}"; do
            local _marker="  "
            [[ "$_p" == "$default_profile" ]] && _marker="${GREEN}*${RESET} "
            # %b on _marker so its embedded ANSI ('\033[32m') is interpreted;
            # plain %s on _p since the profile name is literal text.
            printf '    %b%d)%b %b%s\n' "$BOLD" "$_i" "$RESET" "$_marker" "$_p"
            ((_i++))
        done
        printf '\n'
        printf '  %bExtra tools%b   (comma-separated, optional)\n' "$BOLD" "$RESET"
        printf '  %bExclude tools%b (comma-separated, optional)\n' "$BOLD" "$RESET"
        printf '\n'
        printf '    %b[ENTER]%b confirm   %b[d]%b defaults   %b[q]%b cancel\n\n' \
            "$BOLD$GREEN" "$RESET" "$BOLD$YELLOW" "$RESET" "$BOLD$RED" "$RESET"
    } > /dev/tty

    local choice extra exclude
    # Profile picker
    printf '%bProfile [%s]:%b ' "$BOLD" "$default_profile" "$RESET" > /dev/tty
    IFS= read -r choice < /dev/tty || { echo > /dev/tty; return 1; }
    case "$choice" in
        q|Q) printf '%bcancelled%b\n' "$YELLOW" "$RESET" > /dev/tty; return 1 ;;
        d|D) ;;   # defaults — keep current values, no further prompts
        '')  ;;   # empty — keep default
        [0-9]*)
            if (( choice >= 1 && choice <= ${#profiles[@]} )); then
                export DOTFILES_PROFILE="${profiles[$((choice-1))]}"
            else
                printf '%binvalid choice, using default%b\n' "$YELLOW" "$RESET" > /dev/tty
            fi
            ;;
        *)
            # Allow typing the profile name directly.
            local _ok=false
            for _p in "${profiles[@]}"; do
                [[ "$_p" == "$choice" ]] && { export DOTFILES_PROFILE="$_p"; _ok=true; break; }
            done
            $_ok || printf '%bunknown profile "%s", using default%b\n' "$YELLOW" "$choice" "$RESET" > /dev/tty
            ;;
    esac

    # Skip extras/excludes prompts if 'd' (defaults).
    if [[ "$choice" != "d" && "$choice" != "D" ]]; then
        printf '%bExtra tools [%s]:%b '   "$BOLD" "$default_extra"   "$RESET" > /dev/tty
        IFS= read -r extra   < /dev/tty || extra=""
        [[ -n "$extra" ]]   && export DOTFILES_EXTRA="$(printf '%s' "$extra"   | tr -d '[:space:]')"

        printf '%bExclude tools [%s]:%b ' "$BOLD" "$default_exclude" "$RESET" > /dev/tty
        IFS= read -r exclude < /dev/tty || exclude=""
        [[ -n "$exclude" ]] && export DOTFILES_EXCLUDE="$(printf '%s' "$exclude" | tr -d '[:space:]')"
    fi

    save_config
    {
        printf '\n%bUsing:%b profile=%s extra=%s exclude=%s\n\n' \
            "$BOLD$GREEN" "$RESET" \
            "${DOTFILES_PROFILE:-$DEFAULT_PROFILE}" \
            "${DOTFILES_EXTRA:-(none)}" \
            "${DOTFILES_EXCLUDE:-(none)}"
    } > /dev/tty
    return 0
}

install_dotfiles() {
    # Mode detection: curl-pipe = no .git AND no TTY stdin. Everything else
    # is local (script invoked on a checked-out repo or rerun after install).
    local mode=local
    if is_fresh_install && [[ ! -t 0 ]]; then
        mode=curl
    fi

    _install_welcome "$mode"
    setup_environment

    if is_fresh_install; then
        clone_repository_if_missing || {
            _dotfiles_log_error "Repository setup failed"
            _dotfiles_log_hint "check network reachability or set DOTFILES_REPO=<url>"
            return 1
        }
    fi

    # UC-18: interactive menu is OPT-IN (not default). Daily `dotfiles install`
    # runs silently with whatever's saved in ~/.zshenv. Fire the menu only
    # when explicitly requested:
    #   --menu              flag on this run
    #   DOTFILES_MENU=true  env override (persistable via `dotfiles config set menu true`)
    # Still requires a usable TTY (works under `curl | bash` via /dev/tty).
    local _menu_requested=false
    [[ "${_DOTFILES_INSTALL_MENU:-false}" == "true" ]] && _menu_requested=true
    [[ "${DOTFILES_MENU:-false}"          == "true" ]] && _menu_requested=true
    if $_menu_requested \
        && [[ "${DOTFILES_QUIET:-false}" != "true" ]] \
        && [[ -r /dev/tty ]] && [[ -w /dev/tty ]]; then
        _install_interactive_menu || {
            _dotfiles_log_warning "install cancelled by user"
            return 0
        }
    fi

    create_symlinks
    install_packages
    configure_profile

    _install_done "$mode"
    _install_handle_reload "$mode"
}

# =============================================================================
# Uninstallation
# =============================================================================
# Remove symlinks from a directory
remove_symlinks_from_dir() {
    local source_dir="$1"
    local target_prefix="$2"
    local unlink_count_ref="$3"

    [[ ! -d "$source_dir" ]] && return 0

    for item in "$source_dir"/*; do
        [[ ! -e "$item" ]] && continue

        local name=$(basename "$item")
        local target="$target_prefix$name"

        # Honor caller-provided ":"-separated exclusion list
        if [[ -n "${DOTFILES_CONFIG_EXCLUDE:-}" ]] && [[ ":${DOTFILES_CONFIG_EXCLUDE}:" == *":${name}:"* ]]; then
            continue
        fi

        local link_target
        link_target="$(readlink "$target" 2>/dev/null)"
        if [[ -L "$target" ]] && [[ "$link_target" == "$DOTFILES_ROOT/"* || "$link_target" == "$DOTFILES_ROOT" ]]; then
            rm "$target" && printf -v "$unlink_count_ref" '%d' "$((${!unlink_count_ref} + 1))"
        fi
    done
}

uninstall_dotfiles() {
    _dotfiles_log_warning "This will remove all dotfiles symlinks, packages, and the repo dir"

    if is_interactive; then
        echo -n "Are you sure? [y/N]: "
        read -r response
        [[ ! "$response" =~ ^[Yy]$ ]] && { _dotfiles_log_info "Uninstallation cancelled"; return 0; }
    fi

    show_section "Uninstall"

    # 1. Reverse-iterate active-profile packages and dispatch pkg_uninstall
    _dotfiles_log_step "Asking packages to uninstall (reverse order)"
    local -a all_pkgs=() failed_pkgs=()
    while IFS= read -r f; do all_pkgs+=("$f"); done < <(_iter_profile_packages)

    local i pkg_file pkg_name rc
    for (( i=${#all_pkgs[@]}-1; i>=0; i-- )); do
        pkg_file="${all_pkgs[$i]}"
        pkg_name="$(basename "$pkg_file" .zsh)"
        pkg_name="${pkg_name#[0-9][0-9]-}"
        _dispatch_pkg_hook "$pkg_file" pkg_uninstall
        rc=$?
        case $rc in
            0) _dotfiles_log_result "$pkg_name" "uninstalled" ;;
            2) _dotfiles_log_error "$pkg_name: pkg_uninstall is REQUIRED but missing"
               failed_pkgs+=("$pkg_name|pkg_uninstall hook not defined|N/A|implement pkg_uninstall in $pkg_file") ;;
            *)
               local _err="${_PKG_UNINSTALL_ERROR:-rc=$rc}"
               local _rem="${_PKG_UNINSTALL_REMAINING:-see hook output above}"
               local _rec="${_PKG_UNINSTALL_RECOVERY:-investigate manually}"
               failed_pkgs+=("$pkg_name|$_err|$_rem|$_rec")
               unset _PKG_UNINSTALL_ERROR _PKG_UNINSTALL_REMAINING _PKG_UNINSTALL_RECOVERY
               ;;
        esac
    done

    # 2. Print failure summary (cause + remaining + recovery, per PRD contract)
    if [[ ${#failed_pkgs[@]} -gt 0 ]]; then
        echo
        _dotfiles_log_warning "${#failed_pkgs[@]} package uninstall(s) failed:"
        local entry name err rem rec
        for entry in "${failed_pkgs[@]}"; do
            IFS='|' read -r name err rem rec <<< "$entry"
            _dotfiles_log_warning "$name:"
            _dotfiles_log_dim "  error:     $err"
            _dotfiles_log_dim "  remaining: $rem"
            _dotfiles_log_dim "  recovery:  $rec"
        done
        echo
        _dotfiles_log_warning "Continuing with symlink and repo removal."
    fi

    # 3. Remove symlinks (preserves CONFIG_EXCLUDE handling)
    local unlink_count=0
    remove_symlinks_from_dir "$DOTFILES_ROOT" "$HOME/." unlink_count
    DOTFILES_CONFIG_EXCLUDE="claude:mise" \
        remove_symlinks_from_dir "$DOTFILES_ROOT/config" "$HOME/.config/" unlink_count
    [[ -d "$DOTFILES_ROOT/config/claude" ]] && \
        remove_symlinks_from_dir "$DOTFILES_ROOT/config/claude" "$HOME/.claude/" unlink_count
    [[ -d "$DOTFILES_ROOT/config/mise/conf.d" ]] && \
        remove_symlinks_from_dir "$DOTFILES_ROOT/config/mise/conf.d" "$HOME/.config/mise/conf.d/" unlink_count

    # 3b. tmux: remove ~/.tmux.conf symlink + TPM, regardless of tmux presence
    _dotfiles_tmux_uninstall

    # 4. Strip the dotfiles-managed config from zshenv (UC-15). Remove the
    # whole marker-delimited block first, then any legacy bare exports /
    # header left by pre-marker installs. User content outside is preserved.
    [[ -f "$CONFIG_FILE" ]] && {
        sed_inplace "$CONFIG_FILE" '/^# DOTFILES MANAGED BEGIN/,/^# DOTFILES MANAGED END/d'
        sed_inplace "$CONFIG_FILE" '/^export DOTFILES_/d'
        sed_inplace "$CONFIG_FILE" '/^# Dotfiles Configuration/d'
    }

    # 5. Remove the dotfiles directory — validate path before deletion
    # Guards against a misconfigured DOTFILES_ROOT wiping unintended directories
    if [[ -d "$DOTFILES_ROOT" ]]; then
        if [[ "$DOTFILES_ROOT" != "$HOME/"* ]] || [[ ! -d "$DOTFILES_ROOT/.git" ]]; then
            _dotfiles_log_error "Refusing to remove '$DOTFILES_ROOT' — not a git repo under \$HOME"
            _dotfiles_log_error "Delete it manually if intended: rm -rf '$DOTFILES_ROOT'"
            return 1
        fi
        rm -rf "$DOTFILES_ROOT"
    fi

    # Clean up config backups created by save_config
    rm -f "${CONFIG_FILE}.backup" "${CONFIG_FILE}.backup.1" \
          "${CONFIG_FILE}.backup.2" "${CONFIG_FILE}.backup.3" 2>/dev/null || true

    echo
    if [[ ${#failed_pkgs[@]} -eq 0 ]]; then
        _dotfiles_log_summary "Uninstalled $unlink_count symlinks, all packages, and dotfiles repo"
    else
        _dotfiles_log_summary "Uninstalled $unlink_count symlinks and dotfiles repo. ${#failed_pkgs[@]} package(s) need manual cleanup (see above)."
    fi
}

# =============================================================================
# Clean — safe symlink + leftover cleanup
# =============================================================================
# Algorithm guarantees:
#   1. Only touches symlinks — never files or directories
#   2. Only removes links whose target points INTO the dotfiles repo
#      (user's own symlinks to other locations are never touched)
#   3. Only removes links whose target is missing (active links stay)
#   4. vfox leftovers (~/.version-fox etc.) → hint only, never auto-delete
#   5. Dry-run by default; --force required to apply
clean_dotfiles() {
    local force=false
    [[ "${1:-}" == "--force" ]] && force=true

    cd "$DOTFILES_ROOT" 2>/dev/null || {
        _dotfiles_log_error "DOTFILES_ROOT not accessible: $DOTFILES_ROOT"
        return 1
    }

    show_section "Clean"
    if $force; then
        _dotfiles_log_step "Removing orphaned symlinks and stale state"
    else
        _dotfiles_log_step "Scanning for orphaned state (dry-run)"
        _dotfiles_log_detail "Pass --force to actually apply removals."
    fi

    # (dir, max-depth) — restrict $HOME to direct children so links also seen
    # under $HOME/.config etc. don't double-count.
    local scan_specs=("$HOME/.config:2" "$HOME/.claude:2" "$HOME:1")
    local found=0 removed=0
    local link target resolved dir maxdepth

    for spec in "${scan_specs[@]}"; do
        dir="${spec%:*}"
        maxdepth="${spec#*:}"
        [[ -d "$dir" ]] || continue
        while IFS= read -r link; do
            target="$(readlink "$link" 2>/dev/null)" || continue
            resolved="$(cd "$(dirname "$link")" 2>/dev/null && readlink -f "$link" 2>/dev/null || true)"

            # Skip anything that doesn't point into our repo
            if [[ "$target" != "$DOTFILES_ROOT"* && "$resolved" != "$DOTFILES_ROOT"* ]]; then
                continue
            fi

            # Orphan candidate? Three conditions count as orphan:
            #   1. Target is missing (file deleted from repo)
            #   2. Basename matches EXCLUDE_PATTERNS — e.g. ~/README.md left
            #      over from before that name landed in the exclude list.
            #   3. The symlink points to a DIRECTORY in the repo and lives
            #      directly under $HOME — repo dirs (bin/, zsh/, docs/) must
            #      never end up as ~/.bin / ~/.zsh / etc.
            local _basename _basename_stripped
            _basename="$(basename "$link")"
            # Repo-root → $HOME convention prefixes a leading dot, so the
            # link is named .Makefile but EXCLUDE_PATTERNS lists Makefile.
            # Strip one leading dot before matching.
            _basename_stripped="${_basename#.}"
            local _is_orphan=false
            [[ ! -e "$resolved" ]] && _is_orphan=true
            should_exclude "$_basename" && _is_orphan=true
            should_exclude "$_basename_stripped" && _is_orphan=true
            # Directory symlink directly under $HOME pointing into the repo
            if [[ -d "$resolved" && "$(dirname "$link")" == "$HOME" ]]; then
                _is_orphan=true
            fi
            $_is_orphan || continue

            ((found++))
            if $force; then
                if rm "$link" 2>/dev/null; then
                    ((removed++))
                    _dotfiles_log_success "Removed: $link → $target"
                else
                    _dotfiles_log_warning "Failed to remove: $link"
                fi
            else
                _dotfiles_log_detail "Would remove: $link → $target"
            fi
        done < <(find "$dir" -mindepth 1 -maxdepth "$maxdepth" -type l 2>/dev/null)
    done

    # Per-package clean dispatch
    _dotfiles_log_step "Asking packages to declare cleanable state"
    local pkg_file pkg_name rc
    local clean_arg=""
    $force && clean_arg="--force"
    while IFS= read -r pkg_file; do
        pkg_name="$(basename "$pkg_file" .zsh)"
        pkg_name="${pkg_name#[0-9][0-9]-}"
        # Pass force flag via env var; hook reads ${DOTFILES_CLEAN_FORCE:-} to decide dry-run vs apply
        DOTFILES_CLEAN_FORCE="$clean_arg" _dispatch_pkg_hook "$pkg_file" pkg_clean
        rc=$?
        case $rc in
            0) ;;  # success — hook already printed its own status
            2) is_verbose && _dotfiles_log_dim "$pkg_name: no pkg_clean defined (skip)" ;;
            *) _dotfiles_log_warning "$pkg_name: clean returned $rc" ;;
        esac
    done < <(_iter_profile_packages)

    if [[ $found -eq 0 ]]; then
        _dotfiles_log_summary "Nothing to clean (symlinks)"
    elif $force; then
        _dotfiles_log_summary "Removed $removed of $found orphaned symlink(s)"
    else
        _dotfiles_log_summary "Found $found orphaned symlink(s). Re-run with --force to apply."
    fi
}

# =============================================================================
# Claude-clean — strip session-volatile keys from the synced settings.json so
# `git status` stops showing churn from every /model, /effort, or UI toggle.
#
# Kept (real config that should sync across machines):
#   permissions, hooks, enabledPlugins, extraKnownMarketplaces, statusLine,
#   env, skillListingBudgetFraction
#
# Stripped (per-session preferences that flip while using the tool):
#   model, effortLevel, awaySummaryEnabled, preferredNotifChannel,
#   inputNeededNotifEnabled, skipAutoPermissionPrompt, feedbackSurveyState,
#   lastOnboardingVersion, subscriptionNoticeCount, firstStartTime
#
# Dry-run by default; --force to apply. Requires jq.
# =============================================================================
claude_clean() {
    local force=false
    [[ "${1:-}" == "--force" ]] && force=true

    local target="$DOTFILES_ROOT/config/claude/settings.json"

    show_section "Claude clean"

    if ! command -v jq >/dev/null 2>&1; then
        _dotfiles_log_error "jq required but not installed"
        _dotfiles_log_hint "install with: dotfiles config set profile full && dotfiles install"
        return 1
    fi
    if [[ ! -f "$target" ]]; then
        _dotfiles_log_error "settings.json not found: $target"
        return 1
    fi

    # Noise keys to drop. Edit this list when new churn fields show up.
    local -a noise=(
        model effortLevel awaySummaryEnabled preferredNotifChannel
        inputNeededNotifEnabled skipAutoPermissionPrompt
        feedbackSurveyState lastOnboardingVersion subscriptionNoticeCount
        firstStartTime
    )

    # Build the jq `del(...)` argument list once.
    local del_args="" k
    for k in "${noise[@]}"; do
        [[ -n "$del_args" ]] && del_args+=", "
        del_args+=".${k}"
    done

    local tmp
    tmp="$(mktemp)" || { _dotfiles_log_error "mktemp failed"; return 1; }
    if ! jq "del(${del_args})" "$target" > "$tmp"; then
        rm -f "$tmp"
        _dotfiles_log_error "jq filter failed"
        return 1
    fi

    # Report which keys were actually present (only those count as drift).
    local present=0 removed=()
    for k in "${noise[@]}"; do
        if jq -e "has(\"$k\")" "$target" >/dev/null 2>&1; then
            removed+=("$k")
            ((present++))
        fi
    done

    if (( present == 0 )); then
        _dotfiles_log_summary "Already clean — no volatile keys present."
        rm -f "$tmp"
        return 0
    fi

    if $force; then
        if cmp -s "$tmp" "$target"; then
            _dotfiles_log_summary "Already clean — nothing to write."
            rm -f "$tmp"
            return 0
        fi
        mv "$tmp" "$target"
        _dotfiles_log_step "Stripped $present volatile key(s):"
        for k in "${removed[@]}"; do _dotfiles_log_detail "$k"; done
        _dotfiles_log_summary "Wrote $target"
    else
        _dotfiles_log_step "Would strip $present volatile key(s) (dry-run):"
        for k in "${removed[@]}"; do _dotfiles_log_detail "$k"; done
        _dotfiles_log_detail "Pass --force to apply."
        rm -f "$tmp"
    fi
}

# =============================================================================
# Doctor — read-only diagnostics
# =============================================================================
# Reports health of: required tools, symlinks, package install status,
# PATH sanity, vfox SDK availability. Never modifies state.
# Exit code = number of issues found (0 = healthy).
doctor_dotfiles() {
    local issues=0

    show_section "Doctor"

    # =========================================================================
    # Health-grid header — fast pre-pass that paints one badge per category.
    # Detailed per-check output follows below. Categories: Tools, Repo,
    # Symlinks, Stale, Packages.
    # =========================================================================
    local tools_ok=1 t
    for t in git curl zsh; do
        command -v "$t" >/dev/null 2>&1 || tools_ok=0
    done

    local repo_status="OK"
    if [[ ! -d "$DOTFILES_ROOT/.git" ]]; then
        repo_status="FAIL"
    elif ! git -C "$DOTFILES_ROOT" diff --quiet HEAD 2>/dev/null; then
        repo_status="WARN"
    fi

    # Broken symlink count (quick scan, reused below)
    local _broken=0 _spec _dir _maxdepth _link _resolved
    for _spec in "$HOME/.config:2" "$HOME/.claude:2" "$HOME:1"; do
        _dir="${_spec%:*}"; _maxdepth="${_spec#*:}"
        [[ -d "$_dir" ]] || continue
        while IFS= read -r _link; do
            _resolved="$(cd "$(dirname "$_link")" 2>/dev/null && readlink -f "$_link" 2>/dev/null || true)"
            [[ "$_resolved" == "$DOTFILES_ROOT"* && ! -e "$_resolved" ]] && ((_broken++))
        done < <(find "$_dir" -mindepth 1 -maxdepth "$_maxdepth" -type l 2>/dev/null)
    done

    local stale_ok=1
    [[ -d "$HOME/.version-fox" || -d "$HOME/.config/vfox" ]] && stale_ok=0

    echo
    (( tools_ok )) && _dotfiles_badge OK "Tools" || _dotfiles_badge FAIL "Tools"
    case "$repo_status" in
        OK)   _dotfiles_badge OK   "Repo" ;;
        WARN) _dotfiles_badge WARN "Repo (dirty)" ;;
        FAIL) _dotfiles_badge FAIL "Repo (no .git)" ;;
    esac
    if (( _broken == 0 )); then
        _dotfiles_badge OK "Symlinks"
    else
        _dotfiles_badge WARN "Symlinks ($_broken broken)"
    fi
    (( stale_ok )) && _dotfiles_badge OK "Stale" || _dotfiles_badge WARN "Stale (vfox leftovers)"
    echo

    # =========================================================================
    # Detailed checks (existing behavior)
    # =========================================================================

    # 1. Required tools
    _dotfiles_log_step "Checking required tools"
    local tool
    for tool in git curl zsh; do
        if command -v "$tool" >/dev/null 2>&1; then
            _dotfiles_log_result "$tool" "$(command -v "$tool")"
        else
            _dotfiles_log_error "$tool not found in PATH"
            ((issues++))
        fi
    done

    # 2. Repository state
    _dotfiles_log_step "Checking repository"
    if [[ -d "$DOTFILES_ROOT/.git" ]]; then
        local head_sha branch dirty="clean"
        head_sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo "?")"
        branch="$(git -C "$DOTFILES_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo "detached")"
        if ! git -C "$DOTFILES_ROOT" diff --quiet HEAD 2>/dev/null; then
            dirty="dirty"
        fi
        _dotfiles_log_result "repo" "$DOTFILES_ROOT @ $branch $head_sha ($dirty)"
    else
        _dotfiles_log_error "Not a git repository: $DOTFILES_ROOT"
        ((issues++))
    fi

    # 3. Symlink integrity — count broken/orphaned (don't print each)
    _dotfiles_log_step "Checking symlinks"
    local broken=0
    # Same (dir:maxdepth) specs as clean_dotfiles for consistent scan coverage
    local scan_specs=("$HOME/.config:2" "$HOME/.claude:2" "$HOME:1")
    local link resolved dir maxdepth spec
    for spec in "${scan_specs[@]}"; do
        dir="${spec%:*}"
        maxdepth="${spec#*:}"
        [[ -d "$dir" ]] || continue
        while IFS= read -r link; do
            resolved="$(cd "$(dirname "$link")" 2>/dev/null && readlink -f "$link" 2>/dev/null || true)"
            if [[ "$resolved" == "$DOTFILES_ROOT"* ]] && [[ ! -e "$resolved" ]]; then
                ((broken++))
            fi
        done < <(find "$dir" -mindepth 1 -maxdepth "$maxdepth" -type l 2>/dev/null)
    done
    if [[ $broken -eq 0 ]]; then
        _dotfiles_log_detail "All managed symlinks resolve"
    else
        _dotfiles_log_warning "$broken orphaned symlink(s) — run 'dotfiles clean'"
        ((issues++))
    fi

    # 4. vfox leftovers — post-migration, mise is the canonical version
    # manager, so ~/.local/share/mise + ~/.config/mise are EXPECTED dirs.
    # The check now looks for stale vfox state from the old setup.
    _dotfiles_log_step "Checking for stale version manager state"
    if [[ -d "$HOME/.version-fox" || -d "$HOME/.config/vfox" ]]; then
        _dotfiles_log_warning "vfox leftovers detected — run 'dotfiles clean --force'"
        ((issues++))
    else
        _dotfiles_log_detail "No stale version-manager state"
    fi

    # 5. Per-package doctor (replaces hardcoded vfox check)
    _dotfiles_log_step "Checking packages"
    local pkg_file pkg_name rc
    while IFS= read -r pkg_file; do
        pkg_name="$(basename "$pkg_file" .zsh)"
        pkg_name="${pkg_name#[0-9][0-9]-}"
        _dispatch_pkg_hook "$pkg_file" pkg_doctor
        rc=$?
        case $rc in
            0) ;;  # success — hook already printed its own result
            2) is_verbose && _dotfiles_log_dim "$pkg_name: no pkg_doctor defined (skip)" ;;
            *) _dotfiles_log_warning "$pkg_name: doctor returned $rc"; ((issues+=rc)) ;;
        esac
    done < <(_iter_profile_packages)

    # 6. tmux — silent skip when not installed (machine-optional)
    if command -v tmux &>/dev/null; then
        _dotfiles_log_step "Checking tmux"
        _dotfiles_tmux_doctor
    fi

    echo
    if [[ $issues -eq 0 ]]; then
        _dotfiles_log_summary "Healthy — 0 issues"
    else
        _dotfiles_log_summary "Found $issues issue(s)"
    fi
    return $issues
}

# =============================================================================
# CLI Package Iteration Helpers
# =============================================================================

# Emit absolute paths of every package file in the active profile, one per line.
# Forward (alphabetical) order. Reverse with a counter loop where needed.
_iter_profile_packages() {
    local profile="${DOTFILES_PROFILE:-$DEFAULT_PROFILE}"
    local dir f
    while IFS= read -r dir; do
        [[ -d "$dir" ]] || continue
        for f in "$dir"/*.zsh; do
            [[ -f "$f" ]] && echo "$f"
        done
    done < <(dotfiles_profile_dirs "$profile")
}

# Run a single package hook via zsh and propagate the helper's exit code.
# Args: <package_file> <hook_name>
# Returns: 0=ok, 1=failure, 2=hook not defined, N=propagated from hook
#
# For pkg_uninstall hooks: creates a temp report file, exports its path into
# the subshell via _PKG_UNINSTALL_REPORT_FILE. On failure the hook writes:
#   ERROR=<message>
#   REMAINING=<paths still on disk>
#   RECOVERY=<command to finish manually>
# The dispatcher reads those into bash-scope vars so uninstall_dotfiles can
# populate its failure-summary table. Unset between packages.
_dispatch_pkg_hook() {
    local pkg_file="$1" hook_name="$2"
    local report_file=""

    if [[ "$hook_name" == "pkg_uninstall" ]]; then
        report_file="$(mktemp)" || report_file=""
    fi

    # Pass all values through env + positional args — NEVER string-interpolate
    # them into the zsh -c script body. A DOTFILES_ROOT path with a space or
    # quote would otherwise corrupt or inject the dispatch.
    DOTFILES_ROOT="$DOTFILES_ROOT" \
    DOTFILES_VERBOSE="${DOTFILES_VERBOSE:-false}" \
    _PKG_UNINSTALL_REPORT_FILE="$report_file" \
    zsh -c '
        source "$DOTFILES_ROOT/zsh/lib/log.sh"
        source "$DOTFILES_ROOT/zsh/lib/platform.zsh"
        source "$DOTFILES_ROOT/zsh/lib/installer.zsh"
        _dotfiles_invoke_package_hook "$1" "$2"
    ' _dispatch_pkg_hook "$pkg_file" "$hook_name"
    local rc=$?

    # Read failure vars from the report file into bash scope
    if [[ -n "$report_file" && -f "$report_file" && $rc -ne 0 ]]; then
        local _line _key _val
        while IFS='=' read -r _key _val; do
            case "$_key" in
                ERROR)     _PKG_UNINSTALL_ERROR="$_val" ;;
                REMAINING) _PKG_UNINSTALL_REMAINING="$_val" ;;
                RECOVERY)  _PKG_UNINSTALL_RECOVERY="$_val" ;;
            esac
        done < "$report_file"
    fi
    [[ -n "$report_file" ]] && rm -f "$report_file"

    return $rc
}

# =============================================================================
# Interactive menu — static, man-page styled, zero-flicker.
#
# Renders ONCE per cycle. User types a selection key, action runs (or returns
# rc=1 to quit), screen is cleared and menu repaints once. No redraw between
# keystrokes, no arrow-key polling, no cursor hide/show, no traps.
#
# Pure bash. No external tools. Works on bare bash 3.2+ / Debian / Alpine /
# macOS. Non-TTY (CI, piped install) → bypasses menu, runs install_dotfiles.
# =============================================================================

# Selection key → command id. Single source of truth for both the rendered
# table and the dispatcher.
_MENU_KEYS=(1 2 3 4 5 6 7 u q)
_MENU_IDS=(install sync status config doctor clean test uninstall quit)
_MENU_DESC=(
    "Symlink configs + install missing packages (no git pull)"
    "git pull + install in one step (the daily driver)"
    "Snapshot: profile, git state, symlinks, package count"
    "Change profile, toggle verbose, edit raw config"
    "Health check — badge grid + per-package detail"
    "Remove orphaned symlinks (run after deleting a package)"
    "Run the bundled test suite (sandboxed, hermetic)"
    "Remove all symlinks, package configs, and the repo"
    "Exit the menu"
)

# Render the menu page once. Pure print — no input handling, no loops.
# Colored: blue title bar, cyan section headers, white command names, yellow
# state values, green ✓ marks for healthy git state.
_menu_render_page() {
    local cols=72 left="DOTFILES(1)" right="DOTFILES(1)"
    local title="Cross-Platform Dotfiles Manager"
    local pad_l=$(( (cols - ${#left} - ${#title} - ${#right}) / 2 ))
    (( pad_l < 1 )) && pad_l=1
    local pad_r=$(( cols - ${#left} - pad_l - ${#title} - ${#right} ))
    (( pad_r < 1 )) && pad_r=1
    printf '%b%s%*s%b%s%b%*s%s%b\n' \
        "$BOLD$BLUE" "$left" "$pad_l" "" \
        "$BOLD$WHITE" "$title" "$BOLD$BLUE" \
        "$pad_r" "" "$right" "$RESET"
    echo

    # NAME — minimal, one line.
    printf '%bNAME%b\n' "$BOLD$CYAN" "$RESET"
    printf '    %bdotfiles%b — manage shell config and packages across machines\n' \
        "$BOLD$WHITE" "$RESET"
    echo

    # STATE — current saved configuration + live git state.
    printf '%bSTATE%b\n' "$BOLD$CYAN" "$RESET"
    local profile verbose root
    profile="$(_config_saved_value profile 2>/dev/null)"
    verbose="$(_config_saved_value verbose 2>/dev/null)"
    root="$(_config_saved_value root 2>/dev/null)"
    printf '    %bprofile%b   %b%s%b\n' "$GRAY" "$RESET" "$BOLD$YELLOW" "$profile" "$RESET"
    printf '    %bverbose%b   %b%s%b\n' "$GRAY" "$RESET" "$WHITE" "$verbose" "$RESET"
    printf '    %broot%b      %b%s%b\n' "$GRAY" "$RESET" "$WHITE" "${root/#$HOME/~}" "$RESET"

    if [[ -d "$DOTFILES_ROOT/.git" ]]; then
        local branch sha dirty_n dirty_color dirty_label upstream ahead behind
        branch="$(git -C "$DOTFILES_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo detached)"
        sha="$(git -C "$DOTFILES_ROOT" rev-parse --short HEAD 2>/dev/null || echo '?')"
        dirty_n="$(git -C "$DOTFILES_ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
        if [[ "$dirty_n" == "0" ]]; then
            dirty_color="$GREEN"; dirty_label="clean"
        else
            dirty_color="$YELLOW"; dirty_label="${dirty_n} modified"
        fi
        printf '    %bbranch%b    %b%s%b · %b%s%b · %b%s%b\n' \
            "$GRAY" "$RESET" \
            "$BOLD$WHITE" "$branch" "$RESET" \
            "$DIM" "$sha" "$RESET" \
            "$dirty_color" "$dirty_label" "$RESET"

        upstream="$(git -C "$DOTFILES_ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo '')"
        if [[ -n "$upstream" ]]; then
            ahead="$(git -C "$DOTFILES_ROOT" rev-list --count "@{u}..HEAD" 2>/dev/null || echo 0)"
            behind="$(git -C "$DOTFILES_ROOT" rev-list --count "HEAD..@{u}" 2>/dev/null || echo 0)"
            printf '    %bremote%b    %b%s%b · ↑%s ↓%s\n' \
                "$GRAY" "$RESET" \
                "$WHITE" "$upstream" "$RESET" \
                "$ahead" "$behind"
        fi
    fi
    echo

    # COMMANDS — key in bold magenta, name in bold white, desc in gray.
    printf '%bCOMMANDS%b\n' "$BOLD$CYAN" "$RESET"
    local i key id desc
    for i in "${!_MENU_IDS[@]}"; do
        key="${_MENU_KEYS[i]}"
        id="${_MENU_IDS[i]}"
        desc="${_MENU_DESC[i]}"
        printf '    %b%s%b   %b%-10s%b %b%s%b\n' \
            "$BOLD$MAGENTA" "$key" "$RESET" \
            "$BOLD$WHITE" "$id" "$RESET" \
            "$GRAY" "$desc" "$RESET"
    done
    echo

    # TIPS — tells the user what to type.
    printf '%bTIPS%b\n' "$BOLD$CYAN" "$RESET"
    printf '    Type %b1-7%b, %bu%b, %bq%b, or %ba command name%b · empty Enter to refresh state\n' \
        "$BOLD$MAGENTA" "$RESET" "$BOLD$MAGENTA" "$RESET" "$BOLD$MAGENTA" "$RESET" "$BOLD$WHITE" "$RESET"
    printf '    Pick %bconfig%b to toggle verbose or switch profile · %bdotfiles help%b for the full reference\n' \
        "$BOLD$WHITE" "$RESET" "$BOLD$WHITE" "$RESET"
    echo
}

# Map a typed selection key → command id. Empty echo means no match.
_menu_resolve_key() {
    local input="$1" i
    # Direct key match (number or letter).
    for i in "${!_MENU_KEYS[@]}"; do
        if [[ "${_MENU_KEYS[i]}" == "$input" ]]; then
            echo "${_MENU_IDS[i]}"
            return 0
        fi
    done
    # Also accept the command name itself (e.g. `status`, `install`).
    for i in "${!_MENU_IDS[@]}"; do
        if [[ "${_MENU_IDS[i]}" == "$input" ]]; then
            echo "${_MENU_IDS[i]}"
            return 0
        fi
    done
    return 1
}

# Wait for a single keystroke before returning to the menu. Pressing Enter
# (empty read result) also returns. Other keys are ignored.
_menu_pause() {
    echo
    printf '%bPress Enter to return to menu …%b' "$GRAY" "$RESET"
    read -r _ 2>/dev/null || true
}

# Render the Config sub-screen — interactive change of profile / verbose, plus
# raw-file edit. Each line is a self-describing action ("verbose true → false"),
# numbered. Empty Enter or `b` returns to the main menu.
_menu_config_screen() {
    local choice n
    # Parallel arrays: kind/value/label for each numbered action.
    local -a kinds vals labels

    while true; do
        # Rebuild action list each iteration — values can change after we act.
        kinds=(); vals=(); labels=()

        local cur_verbose new_verbose
        cur_verbose="$(_config_saved_value verbose)"
        [[ "$cur_verbose" == "true" ]] && new_verbose="false" || new_verbose="true"
        kinds+=("verbose"); vals+=("$new_verbose")
        labels+=("$(printf '%-9s %b%-5s%b → %b%-5s%b   %b(toggle)%b' \
            "verbose" \
            "$WHITE" "$cur_verbose" "$RESET" \
            "$BOLD$YELLOW" "$new_verbose" "$RESET" \
            "$DIM" "$RESET")")

        local cur_profile p
        cur_profile="$(_config_saved_value profile)"
        while IFS= read -r p; do
            [[ "$p" == "$cur_profile" ]] && continue
            kinds+=("profile"); vals+=("$p")
            labels+=("$(printf '%-9s %b%-5s%b → %b%-5s%b' \
                "profile" \
                "$WHITE" "$cur_profile" "$RESET" \
                "$BOLD$YELLOW" "$p" "$RESET")")
        done < <(list_valid_profiles)

        # exclude / extra — entered as comma-separated lists, empty clears.
        local cur_exclude cur_extra
        cur_exclude="$(_config_saved_value exclude)"
        cur_extra="$(_config_saved_value extra)"
        kinds+=("exclude"); vals+=("")
        labels+=("$(printf '%-9s %b%-30s%b %b(enter new csv)%b' \
            "exclude" \
            "$WHITE" "${cur_exclude:-<none>}" "$RESET" \
            "$DIM" "$RESET")")
        kinds+=("extra"); vals+=("")
        labels+=("$(printf '%-9s %b%-30s%b %b(enter new csv)%b' \
            "extra" \
            "$WHITE" "${cur_extra:-<none>}" "$RESET" \
            "$DIM" "$RESET")")

        kinds+=("edit"); vals+=("")
        labels+=("$(printf '%-9s %b(open %s in %s)%b' \
            "edit file" \
            "$DIM" "${CONFIG_FILE/#$HOME/~}" "${EDITOR:-vi}" "$RESET")")

        # ---- Render the screen ----
        clear 2>/dev/null

        # Centered title bar
        local cols=72 left="DOTFILES(1)" right="DOTFILES(1)" title="Config"
        local pad_l=$(( (cols - ${#left} - ${#title} - ${#right}) / 2 ))
        (( pad_l < 1 )) && pad_l=1
        local pad_r=$(( cols - ${#left} - pad_l - ${#title} - ${#right} ))
        (( pad_r < 1 )) && pad_r=1
        printf '%b%s%*s%b%s%b%*s%s%b\n' \
            "$BOLD$BLUE" "$left" "$pad_l" "" \
            "$BOLD$WHITE" "$title" "$BOLD$BLUE" \
            "$pad_r" "" "$right" "$RESET"
        echo

        # CURRENT — what's saved right now.
        printf '%bCURRENT%b\n' "$BOLD$CYAN" "$RESET"
        printf '    %bprofile%b    %b%-30s%b %b(currently active)%b\n' \
            "$GRAY" "$RESET" "$BOLD$YELLOW" "$cur_profile" "$RESET" "$DIM" "$RESET"
        printf '    %bverbose%b    %b%-30s%b %b(debug output on shell startup)%b\n' \
            "$GRAY" "$RESET" "$WHITE" "$cur_verbose" "$RESET" "$DIM" "$RESET"
        printf '    %bexclude%b    %b%-30s%b %b(per-machine: drop these tools)%b\n' \
            "$GRAY" "$RESET" "$WHITE" "${cur_exclude:-<none>}" "$RESET" "$DIM" "$RESET"
        printf '    %bextra%b      %b%-30s%b %b(per-machine: add these tools)%b\n' \
            "$GRAY" "$RESET" "$WHITE" "${cur_extra:-<none>}" "$RESET" "$DIM" "$RESET"
        printf '    %broot%b       %b%-30s%b %b(repository location)%b\n' \
            "$GRAY" "$RESET" "$WHITE" "${DOTFILES_ROOT/#$HOME/~}" "$RESET" "$DIM" "$RESET"
        echo

        # CHANGE — numbered actionable lines.
        printf '%bCHANGE%b\n' "$BOLD$CYAN" "$RESET"
        local i
        for i in "${!labels[@]}"; do
            printf '    %b%d%b   %s\n' \
                "$BOLD$MAGENTA" $((i + 1)) "$RESET" \
                "${labels[i]}"
        done
        echo
        printf '    %bb%b   back to main menu\n' "$BOLD$MAGENTA" "$RESET"
        echo

        # Prompt — same glyph and color as the main menu.
        printf '  %b❯%b ' "$BOLD$GREEN" "$RESET"
        if ! IFS= read -r choice; then
            echo
            return
        fi

        # ---- Dispatch ----
        case "$choice" in
            ''|b|back|q|quit) return ;;
        esac

        if [[ "$choice" =~ ^[0-9]+$ ]]; then
            n=$((choice - 1))
            if (( n < 0 || n >= ${#kinds[@]} )); then
                _dotfiles_log_error "no option ${choice} (valid: 1-${#kinds[@]}, or b)"
                sleep 1
                continue
            fi
            echo
            case "${kinds[$n]}" in
                verbose|profile)
                    config_set "${kinds[$n]}" "${vals[$n]}"
                    ;;
                exclude|extra)
                    # Prompt for a new comma-separated list. Empty clears the value.
                    local _key="${kinds[$n]}"
                    local _cur _new
                    _cur="$(_config_saved_value "$_key")"
                    printf '%bEnter new %s%b %b(current: %s; empty clears)%b: ' \
                        "$BOLD" "$_key" "$RESET" "$DIM" "${_cur:-<none>}" "$RESET"
                    IFS= read -r _new || _new=""
                    config_set "$_key" "$_new"
                    ;;
                edit)
                    "${EDITOR:-vi}" "$CONFIG_FILE"
                    ;;
            esac
            # Brief pause so user sees the confirmation line before redraw.
            [[ "${kinds[$n]}" != "edit" ]] && sleep 0.6
        else
            _dotfiles_log_error "unknown choice: $choice"
            sleep 1
        fi
    done
}

# Dispatch a command id. Return code semantics: 0 → continue loop, 1 → quit.
_menu_execute() {
    local id="$1"
    case "$id" in
        install)   install_dotfiles;        _menu_pause ;;
        sync)      sync_dotfiles;           _menu_pause ;;
        status)    status_command;          _menu_pause ;;
        config)    _menu_config_screen ;;   # has its own loop, no pause
        doctor)    doctor_dotfiles;         _menu_pause ;;
        clean)     clean_dotfiles;          _menu_pause ;;
        test)      test_dotfiles;           _menu_pause ;;
        uninstall) uninstall_dotfiles && return 1 || _menu_pause ;;
        quit)      return 1 ;;
        *)         return 0 ;;
    esac
    return 0
}

interactive_menu() {
    load_config

    # Non-TTY (piped, CI, headless install) → skip the menu and run install.
    if [[ ! -t 0 || ! -t 1 ]]; then
        install_dotfiles
        return
    fi

    # Menu actions run install/update/sync which would otherwise `exec zsh`
    # at the end and kill the bash menu process. Pin DOTFILES_NO_RELOAD so
    # control returns here. The user can `exec zsh` manually after quitting.
    export DOTFILES_NO_RELOAD=true

    local choice id
    while true; do
        clear
        _menu_render_page
        printf '  %b❯%b ' "$BOLD$GREEN" "$RESET"
        # Single line of input. read -r returns "" on bare Enter, which we
        # treat as a refresh (re-render with updated live state).
        if ! IFS= read -r choice; then
            # EOF (Ctrl-D) — treat as quit.
            echo; break
        fi

        # Empty input → refresh-only (loops back, re-renders the live state).
        [[ -z "$choice" ]] && continue

        # Resolve. Unknown input prints a one-liner and re-renders next cycle.
        if id="$(_menu_resolve_key "$choice")"; then
            _menu_execute "$id" || break
        else
            _dotfiles_log_error "unknown selection: $choice"
            local _sug
            _sug="$(_dotfiles_did_you_mean "$choice" "${_MENU_IDS[@]}" 2>/dev/null)"
            [[ -n "$_sug" ]] && _dotfiles_log_hint "try: $_sug"
            sleep 1
        fi
    done

    echo
    _dotfiles_log_summary "bye"
}

# =============================================================================
# Command Line Interface
# =============================================================================
show_version() {
    echo "dotfiles - Cross-platform dotfiles manager"
    echo "https://github.com/ved0el/dotfiles"
}

show_usage() {
    # Colored man-page rendering. Section headers in bold cyan, command
    # names in bold white, descriptions in gray, examples in bold green.
    local cols=72 left="DOTFILES(1)" right="DOTFILES(1)"
    local title="Cross-Platform Dotfiles Manager"
    local pad_l=$(( (cols - ${#left} - ${#title} - ${#right}) / 2 ))
    (( pad_l < 1 )) && pad_l=1
    local pad_r=$(( cols - ${#left} - pad_l - ${#title} - ${#right} ))
    (( pad_r < 1 )) && pad_r=1
    printf '%b%s%*s%b%s%b%*s%s%b\n' \
        "$BOLD$BLUE" "$left" "$pad_l" "" \
        "$BOLD$WHITE" "$title" "$BOLD$BLUE" \
        "$pad_r" "" "$right" "$RESET"
    echo

    printf '%bNAME%b\n' "$BOLD$CYAN" "$RESET"
    printf '    %bdotfiles%b — manage shell config and packages across machines\n' \
        "$BOLD$WHITE" "$RESET"
    echo

    printf '%bSYNOPSIS%b\n' "$BOLD$CYAN" "$RESET"
    printf '    %bdotfiles%b [%b-v%b|%b-q%b|%b--json%b|%b--no-reload%b|%b--no-banner%b] [%bCOMMAND%b] [%bARGS%b]\n' \
        "$BOLD$WHITE" "$RESET" \
        "$YELLOW" "$RESET" "$YELLOW" "$RESET" "$YELLOW" "$RESET" "$YELLOW" "$RESET" "$YELLOW" "$RESET" \
        "$BOLD$WHITE" "$RESET" "$DIM" "$RESET"
    echo

    printf '%bCOMMANDS%b\n' "$BOLD$CYAN" "$RESET"
    _help_cmd "install"   "i"  "Symlink configs and install packages (default)"
    _help_cmd "update"    "u"  "git pull --rebase (use --stash on dirty tree)"
    _help_cmd "sync"      "s"  "update + install in one step"
    _help_cmd "status"    "st" "Snapshot of profile, git, symlinks, packages"
    _help_cmd "config"    ""   "get/set/list/edit/path/keys configuration"
    _help_cmd "profile"   "p"  "list | <name> — show or set the active profile"
    _help_cmd "doctor"    "d"  "Read-only health check (badge grid + detail)"
    _help_cmd "clean"     "c"  "Remove orphaned symlinks (dry-run default)"
    _help_cmd "claude-clean" "" "Strip session-volatile keys from claude settings.json"
    _help_cmd "link"      ""   "Refresh symlinks only (no package work)"
    _help_cmd "packages"  ""   "Install packages for current profile"
    _help_cmd "test"      "t"  "Run the bundled test suite (sandboxed, hermetic)"
    _help_cmd "uninstall" ""   "Remove all symlinks, package configs, and repo"
    _help_cmd "version"   ""   "Show version and source URL"
    _help_cmd "help"      ""   "Show this help message"
    echo

    printf '%bOPTIONS%b\n' "$BOLD$CYAN" "$RESET"
    _help_opt "-v, --verbose"  "Verbose output (shell startup + CLI details)"
    _help_opt "-q, --quiet"    "Suppress non-error output"
    _help_opt "--json"         "Machine-readable JSON (status, config list)"
    _help_opt "--no-reload"    "Skip 'exec zsh' at the end of install/update"
    _help_opt "--no-banner"    "Skip the dotfiles banner (handy for scripts/CI)"
    _help_opt "-h, --help"     "Show this help message"
    printf '    %bGlobal flags may appear before or after the subcommand.%b\n' "$DIM" "$RESET"
    echo

    printf '%bEXAMPLES%b\n' "$BOLD$CYAN" "$RESET"
    _help_ex "dotfiles"                              "Open the interactive menu"
    _help_ex "dotfiles install"                      "Symlinks + packages (no git)"
    _help_ex "dotfiles profile list"                 "Show profile contents and active marker"
    _help_ex "dotfiles config set profile develop"   "Switch active profile"
    _help_ex "dotfiles config set extra tmux"        "Opt-in tmux on this machine"
    _help_ex "dotfiles config edit"                  "Open the managed block in \$EDITOR"
    _help_ex "dotfiles update --stash"               "Pull latest, auto-stash local changes"
    _help_ex "dotfiles doctor"                       "Run the health check"
    echo

    printf '%bONE-LINE INSTALL%b  %b(clean machine)%b\n' "$BOLD$CYAN" "$RESET" "$DIM" "$RESET"
    printf '    %bcurl -fsSL %s | bash%b\n' "$BOLD$GREEN" "$INSTALL_COMMAND_URL" "$RESET"
    echo

    printf '%bSEE ALSO%b\n' "$BOLD$CYAN" "$RESET"
    printf '    %bdotfiles config help%b · %bdotfiles status%b · %bdotfiles doctor%b\n' \
        "$BOLD$WHITE" "$RESET" "$BOLD$WHITE" "$RESET" "$BOLD$WHITE" "$RESET"
    echo
    printf '    %bSource:%b %s\n' "$GRAY" "$RESET" "$DOCS_URL"
}

# Render one COMMANDS row: bold name, dim alias, gray description.
# Args: <name> <alias-or-empty> <description>
_help_cmd() {
    local name="$1" alias="$2" desc="$3"
    if [[ -n "$alias" ]]; then
        printf '    %b%-10s%b %b%-3s%b  %b%s%b\n' \
            "$BOLD$WHITE" "$name" "$RESET" \
            "$DIM" "$alias" "$RESET" \
            "$GRAY" "$desc" "$RESET"
    else
        printf '    %b%-10s%b      %b%s%b\n' \
            "$BOLD$WHITE" "$name" "$RESET" \
            "$GRAY" "$desc" "$RESET"
    fi
}

# Render one OPTIONS row.
_help_opt() {
    printf '    %b%-16s%b  %b%s%b\n' \
        "$BOLD$YELLOW" "$1" "$RESET" \
        "$GRAY" "$2" "$RESET"
}

# Render one EXAMPLES row.
_help_ex() {
    printf '    %b$%b %b%-40s%b  %b# %s%b\n' \
        "$DIM" "$RESET" \
        "$BOLD$GREEN" "$1" "$RESET" \
        "$DIM" "$2" "$RESET"
}

# =============================================================================
# Main Function
# =============================================================================
# Initialize script environment
init_script() {
    readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    # Captured before any cd; restored before exec zsh so the replacement
    # shell starts in the user's original directory, not DOTFILES_ROOT.
    _ORIG_PWD="$PWD"

    # Load existing configuration and set defaults
    load_config
    set_defaults
}

# =============================================================================
# `dotfiles test` — run the bundled test suite (test/run.sh)
# =============================================================================
# Hermetic, zero-dependency suite that exercises every command across the
# install/update/sync/clean/uninstall environments in throwaway sandboxes.
# Passes any args straight through (e.g. `dotfiles test -f config`,
# `dotfiles test --shellcheck`).
test_dotfiles() {
    local runner="$DOTFILES_ROOT/test/run.sh"
    if [[ ! -f "$runner" ]]; then
        _dotfiles_log_error "Test runner not found: $runner"
        _dotfiles_log_hint "the suite ships under test/ — run from a full repo checkout"
        return 1
    fi
    command -v bash >/dev/null 2>&1 || { _dotfiles_log_error "bash is required to run the tests"; return 1; }
    bash "$runner" "$@"
}

# Parse and validate command line arguments
parse_args() {
    # Global flag pre-pass — these can appear anywhere in the arg list,
    # before or after the subcommand. Subcommand-specific flags (--stash,
    # --force) are NOT consumed here; they pass through to the handler.
    local -a positional=()
    local arg
    for arg in "$@"; do
        case "$arg" in
            -v|--verbose)   export DOTFILES_VERBOSE="true" ;;
            -q|--quiet)     export DOTFILES_QUIET="true" ;;
            --no-reload)    export DOTFILES_NO_RELOAD="true" ;;
            --no-banner)    export DOTFILES_NO_BANNER="true" ;;
            --json)         export DOTFILES_OUTPUT_FORMAT="json" ;;
            --version)      show_version; exit 0 ;;
            # Install-time flags: profile + per-machine overrides (UC-4/UC-7).
            # Setting any of these marks the install as "user-specified" so the
            # interactive menu (UC-18) doesn't fire later.
            --profile=*)    export DOTFILES_PROFILE="${arg#--profile=}"
                            export _DOTFILES_INSTALL_FLAGS_PROVIDED=true ;;
            --exclude=*)    export DOTFILES_EXCLUDE="${arg#--exclude=}"
                            export _DOTFILES_INSTALL_FLAGS_PROVIDED=true ;;
            --extra=*)      export DOTFILES_EXTRA="${arg#--extra=}"
                            export _DOTFILES_INSTALL_FLAGS_PROVIDED=true ;;
            -y|--yes)       export _DOTFILES_INSTALL_FLAGS_PROVIDED=true ;;
            --menu)         export _DOTFILES_INSTALL_MENU=true ;;
            *)              positional+=("$arg") ;;
        esac
    done
    # bash 3.2 (macOS /bin/bash) errors on "${empty_array[@]}" expansion
    # under `set -u`. Guard explicitly so empty positional is a no-op.
    if (( ${#positional[@]} > 0 )); then
        set -- "${positional[@]}"
    else
        set --
    fi

    local command="${1:-}"
    if [[ "$command" == "-h" || "$command" == "--help" ]]; then
        show_usage
        exit 0
    fi

    # Parse commands. Each command accepts:
    #   - full name:  dotfiles install
    #   - one-letter: dotfiles i             (subcommand style — preferred)
    #   - dash-flag:  dotfiles -i            (legacy, kept for muscle memory)
    case "$command" in
        ""|install|i|-i)
            if is_interactive && [[ -z "$command" ]]; then
                interactive_menu
            else
                install_dotfiles
            fi
            ;;
        update|u|-u)
            update_dotfiles "${2:-}"
            ;;
        sync|s|-s)
            sync_dotfiles "${2:-}"
            ;;
        clean|c|-c)
            clean_dotfiles "${2:-}"
            ;;
        claude-clean)
            claude_clean "${2:-}"
            ;;
        doctor|d|-d)
            doctor_dotfiles
            ;;
        uninstall)
            uninstall_dotfiles
            ;;
        link)
            create_symlinks
            ;;
        profile)
            handle_profile_command "${2:-}"
            ;;
        packages)
            install_packages
            ;;
        config)
            config_command "${@:2}"
            ;;
        status|st)
            status_command
            ;;
        test|t)
            test_dotfiles "${@:2}"
            ;;
        version)
            show_version
            ;;
        help|-h|--help)
            show_usage
            ;;
        *)
            if [[ -n "$command" ]]; then
                _dotfiles_log_error "Unknown command: $command"
                local _sug
                _sug="$(_dotfiles_did_you_mean "$command" \
                    install update sync status config doctor clean claude-clean \
                    uninstall link profile packages test version help \
                    2>/dev/null)"
                [[ -n "$_sug" ]] && _dotfiles_log_hint "did you mean: dotfiles $_sug?"
                echo
                show_usage
                exit 1
            fi
            ;;
    esac
}

# Handle profile command — update only DOTFILES_PROFILE in ~/.zshenv
# Uses targeted sed to replace or append the line (does not rewrite other vars)
handle_profile_command() {
    local new_profile="$1"

    if [[ -z "$new_profile" ]]; then
        _dotfiles_log_error "Profile name required. Usage: $SCRIPT_NAME profile <core|server|develop> | list"
        return 1
    fi

    if [[ "$new_profile" == "list" || "$new_profile" == "ls" ]]; then
        _profile_list
        return $?
    fi

    if ! validate_profile "$new_profile"; then
        return 1
    fi

    local config_file="$CONFIG_FILE"   # ~/.zshenv

    if grep -q "^export DOTFILES_PROFILE=" "$config_file" 2>/dev/null; then
        # Replace existing line in-place
        sed_inplace "$config_file" \
            "s|^export DOTFILES_PROFILE=.*|export DOTFILES_PROFILE=\"${new_profile}\"|"
    else
        # Append if not present
        echo "export DOTFILES_PROFILE=\"${new_profile}\"" >> "$config_file"
    fi

    export DOTFILES_PROFILE="$new_profile"
    _dotfiles_log_success "Profile set to ${new_profile}. Run: source ~/.zshrc"
    return 0
}

# Print the profile table with the active profile marked.
_profile_list() {
    local active="${DOTFILES_PROFILE:-core}"
    local mark
    show_section "Profiles"
    printf '  %-8s  %-32s  %s\n' "NAME" "SHELL-INIT PACKAGES" "MISE SHARDS"
    printf '  %-8s  %-32s  %s\n' "----" "-------------------" "-----------"
    for p in core server develop; do
        mark=" "
        [[ "$active" == "$p" ]] && mark="→"
        case "$p" in
            core)    printf '%s %-8s  %-32s  %s\n' "$mark" "$p" "sheldon, mise" "(none — opt in via 99-machine.toml)" ;;
            server)  printf '%s %-8s  %-32s  %s\n' "$mark" "$p" "core + (server-tier zsh init)" "core + 00-server.toml" ;;
            develop) printf '%s %-8s  %-32s  %s\n' "$mark" "$p" "core + server + mise-tools.zsh" "core + 00-server.toml + 10-develop.toml" ;;
        esac
    done
    echo
    _dotfiles_log_dim "Switch with: dotfiles config set profile <name>"
    return 0
}

main() {
    init_script
    parse_args "$@"
}

# Run main function with error handling
if main "$@"; then
    exit 0
else
    exit 1
fi
