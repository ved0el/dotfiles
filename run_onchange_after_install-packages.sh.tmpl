#!/bin/sh
# Bootstrap packages + plugins. Re-runs automatically whenever this file's rendered
# content changes (e.g. you toggle a profile or add a package). `after_` => runs once
# all dotfiles are applied, so mise's conf.d/*.toml are in place when `mise install`
# runs.
set -eu

# --- base packages: install only what's missing. btop→bottom and tree→eza are handled
#     by mise + shell aliases now, so they're no longer installed via brew/apt. ---
{{ if eq .chezmoi.os "darwin" -}}
command -v brew >/dev/null 2>&1 || /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
# git/curl ship with macOS — only install if somehow absent.
command -v git  >/dev/null 2>&1 || brew install git
command -v curl >/dev/null 2>&1 || brew install curl
{{ if .tmux }}command -v tmux >/dev/null 2>&1 || brew install tmux{{ end }}
# mole — macOS cleanup/optimization CLI (macOS only).
command -v mole >/dev/null 2>&1 || brew install mole
{{ if .wm }}
# macOS window manager (yabai + skhd) from the upstream tap.
brew install koekeishiya/formulae/yabai koekeishiya/formulae/skhd
skhd --start-service || true
echo "[wm] yabai installed — run 'yabai --start-service' (needs SIP setup; see the yabai wiki)"
{{ end }}
{{ else if eq .chezmoi.os "linux" -}}
# Batch a single apt-get for whatever is missing (skip the update entirely if nothing is).
_pkgs=""
command -v git  >/dev/null 2>&1 || _pkgs="$_pkgs git"
command -v curl >/dev/null 2>&1 || _pkgs="$_pkgs curl"
{{ if .tmux }}command -v tmux >/dev/null 2>&1 || _pkgs="$_pkgs tmux"{{ end }}
if [ -n "$_pkgs" ]; then sudo apt-get update -y && sudo apt-get install -y $_pkgs; fi
{{ end -}}

# ~/.local/bin holds self-installed tools (sheldon, mise).
export PATH="$HOME/.local/bin:$PATH"

# --- sheldon (zsh plugin manager) — idempotent; --force overwrites on upgrade ---
command -v sheldon >/dev/null 2>&1 || \
  curl --proto '=https' -fLsS https://rossmacarthur.github.io/install/crate.sh | \
    bash -s -- --force --repo rossmacarthur/sheldon --to "$HOME/.local/bin"

# --- mise (runtimes + CLI tools, cross-platform — drives the tools/develop profiles) ---
command -v mise >/dev/null 2>&1 || \
  curl --proto '=https' --tlsv1.2 -fsSL https://mise.run | sh

{{ if .tmux -}}
# --- tmux plugins (TPM) — server-free install --------------------------------
# A TPM "install" is just `git clone` into ~/.tmux/plugins/<name>, so we clone the
# plugins directly instead of driving tmux. We deliberately DON'T use TPM's own
# bin/install_plugins: it needs a live tmux server that has sourced the config (to
# read TMUX_PLUGIN_MANAGER_PATH), and during a non-interactive bootstrap that path
# was the source of two bugs —
#   1. a session-less `tmux start-server` exits before TPM can query it, so TPM
#      aborted with "not configured" and installed ZERO plugins (silently, because
#      stderr was sent to /dev/null); and
#   2. starting a server on the default socket left a stale server behind, which
#      then made plain `tmux` abort with "server exited unexpectedly" after the
#      next tmux upgrade (old server vs newly-installed client).
# Cloning needs no server, touches no socket, never hides errors, and is safe to
# re-run. TPM still manages updates at runtime via `prefix + I` / `prefix + U`.
tpm_dir="$HOME/.tmux/plugins"
mkdir -p "$tpm_dir"
[ -d "$tpm_dir/tpm" ] || \
  git clone --depth 1 https://github.com/tmux-plugins/tpm "$tpm_dir/tpm"
# Clone every `set -g @plugin 'owner/repo'` (or full git URL) declared in the config
# that isn't present yet. A failed clone warns but never aborts the bootstrap.
sed -n "s/^[[:space:]]*set[^@]*@plugin[[:space:]]*['\"]\([^'\"]*\)['\"].*/\1/p" \
      "$HOME/.tmux.conf" 2>/dev/null \
  | while IFS= read -r plugin; do
      [ -n "$plugin" ] || continue
      name=${plugin##*/}; name=${name%.git}
      if [ -d "$tpm_dir/$name" ]; then continue; fi
      case "$plugin" in
        *://*) url="$plugin" ;;
        *)     url="https://github.com/$plugin" ;;
      esac
      echo "[tmux] installing plugin: $name"
      git clone --depth 1 "$url" "$tpm_dir/$name" \
        || echo "[tmux] WARN: clone failed for $plugin — run 'prefix + I' in tmux to retry"
    done
{{ end -}}

# --- install tools/runtimes declared in ~/.config/mise/conf.d/*.toml, lock sheldon ---
# --cd "$HOME": mise only auto-discovers the global conf.d/*.toml when CWD is inside the home
# tree; chezmoi may run this script from elsewhere, so anchor it at $HOME or nothing installs.
mise --cd "$HOME" install --yes

# rtk (rtk-ai/rtk) — install its Claude Code command-rewrite hook globally. --auto-patch
# edits ~/.claude/settings.json without prompting, keeping this bootstrap non-interactive;
# it's idempotent so re-runs are safe, and `|| true` keeps a hiccup from aborting setup.
command -v rtk >/dev/null 2>&1 && rtk init -g --auto-patch || \
  mise --cd "$HOME" exec -- rtk init -g --auto-patch || true

sheldon lock --update
