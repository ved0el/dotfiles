{{- $tools   := promptBoolOnce . "tools"   "Install productivity tools (ex: bat, fd, ripgrep, etc)" true -}}
{{- $develop := promptBoolOnce . "develop" "Install development tools (ex: nodejs, golang, python, etc)" false -}}
{{- $tmux := false -}}
{{- $wm   := false -}}
{{- if ne .chezmoi.os "windows" -}}
{{-   $tmux = promptBoolOnce . "tmux" "Install tmux + plugins (and manage ~/.tmux.conf)" true -}}
{{- end -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $wm = promptBoolOnce . "wm" "Install the macOS window manager (yabai + skhd) and its config" false -}}
{{- else if eq .chezmoi.os "windows" -}}
{{-   $wm = promptBoolOnce . "wm" "Install the Windows window manager (komorebi + whkd + yasb) and its config" false -}}
{{- end -}}
[data]
    tools   = {{ $tools }}
    develop = {{ $develop }}
    tmux    = {{ $tmux }}
    wm      = {{ $wm }}
{{ if eq .chezmoi.os "windows" }}
# Windows: run the .ps1 bootstrap via pwsh 7 if available, else Windows PowerShell 5.1.
# Resolved to an ABSOLUTE path at init so it works even when neither is on PATH (otherwise
# chezmoi errors: exec "powershell": executable file not found in %PATH%). 5.1 always exists
# at %SystemRoot%\System32\...; the bootstrap installs pwsh for later runs to prefer.
# -ExecutionPolicy Bypass so a Restricted default policy can't block the generated script.
{{- $ps := printf "%s\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" (env "SystemRoot") }}
{{- if lookPath "pwsh" }}{{ $ps = lookPath "pwsh" }}{{ end }}
[interpreters.ps1]
    command = '{{ $ps }}'
    args = ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass"]
{{ end }}
