# Windows bootstrap: scoop (OS package manager) + mise (runtimes/CLI tools). The
# analogue of run_onchange_after_install-packages.sh.tmpl for Unix. chezmoi runs this
# via the [interpreters.ps1] command set in .chezmoi.toml.tmpl. Re-runs automatically
# whenever this file's rendered content changes. tmux / sheldon / TPM are Unix-only
# and intentionally skipped here.
$ErrorActionPreference = 'Stop'

# --- env every later step + the PowerShell profile rely on (persisted for the user) ---
$LocalBin = Join-Path $HOME '.local\bin'
New-Item -ItemType Directory -Force -Path $LocalBin | Out-Null
$XdgConfig = Join-Path $HOME '.config'

function Add-UserPath([string]$Dir) {
  $current = [Environment]::GetEnvironmentVariable('Path', 'User')
  if ($current -notlike "*$Dir*") {
    [Environment]::SetEnvironmentVariable('Path', "$Dir;$current", 'User')
  }
  if ($env:Path -notlike "*$Dir*") { $env:Path = "$Dir;$env:Path" }
}

# ~/.local/bin holds chezmoi (the one-liner installs it there) + other self-installed
# tools. It is NOT on PATH by default on Windows, so persist it.
Add-UserPath $LocalBin

# XDG_CONFIG_HOME so mise (and other XDG-aware tools) read ~/.config/mise/conf.d —
# the SAME manifests used on macOS/Linux. Without this mise looks in %APPDATA%.
[Environment]::SetEnvironmentVariable('XDG_CONFIG_HOME', $XdgConfig, 'User')
$env:XDG_CONFIG_HOME = $XdgConfig

# NOTE: deliberately DO NOT persist MISE_GLOBAL_CONFIG_FILE. mise's default global config is
# already ~/.config/mise/config.toml (chezmoi-ignored, so `mise use -g` pins stay untracked
# there), so setting it is redundant — and it makes mise stop auto-discovering the global
# config DIRECTORY (the conf.d/*.toml tool manifests) when a process runs with CWD outside
# $HOME (Windows Terminal starts at the user's working drive), so `mise ls` shows no tools.
# Earlier revisions set it; clear any stale User-scope value so upgrades self-heal.
if ([Environment]::GetEnvironmentVariable('MISE_GLOBAL_CONFIG_FILE', 'User')) {
  [Environment]::SetEnvironmentVariable('MISE_GLOBAL_CONFIG_FILE', $null, 'User')
}
if ([Environment]::GetEnvironmentVariable('MISE_CONFIG_DIR', 'User')) {
  [Environment]::SetEnvironmentVariable('MISE_CONFIG_DIR', $null, 'User')
}

# Window-manager config homes — point komorebi/whkd/yasb at ~/.config/<tool>. These
# MUST be persisted (User scope): the WM apps launch at startup, outside any shell
# profile. komorebi defaults to ~/komorebi.json and whkd to ~/.config/whkdrc, so without
# these the chezmoi-managed configs under ~/.config/<tool> are not read.
foreach ($wm in 'komorebi','whkd','yasb') {
  $home_ = Join-Path $XdgConfig $wm
  $var = $wm.ToUpper() + '_CONFIG_HOME'
  [Environment]::SetEnvironmentVariable($var, $home_, 'User')
  Set-Item "env:$var" $home_
}

# --- scoop (package manager) — installs per-user; must NOT run elevated ---
if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
  Invoke-RestMethod -Uri 'https://get.scoop.sh' | Invoke-Expression
  $env:Path = "$env:USERPROFILE\scoop\shims;$env:Path"
}

# git: scoop needs it for buckets/updates. pwsh: PowerShell 7, the shell the managed
# profile targets (this bootstrap itself runs under Windows PowerShell 5.1). Install
# only what's missing. (curl ships with Windows 10+, so nothing to do there.)
if (-not (Get-Command git  -ErrorAction SilentlyContinue)) { scoop install git }
if (-not (Get-Command pwsh -ErrorAction SilentlyContinue)) { scoop install pwsh }

# --- mise (runtimes + CLI tools, cross-platform — drives the tools/develop profiles) ---
if (-not (Get-Command mise -ErrorAction SilentlyContinue)) {
  scoop install mise
}

# --- install tools/runtimes declared in ~/.config/mise/conf.d/*.toml ---
# --cd $HOME: mise only auto-discovers the global conf.d/*.toml when CWD is inside the home
# tree; chezmoi may run this script from elsewhere, so anchor it at $HOME or nothing installs.
mise --cd $HOME install --yes

# rtk (rtk-ai/rtk) — install its Claude Code command-rewrite hook globally. --auto-patch
# edits ~/.claude/settings.json without prompting, keeping this bootstrap non-interactive;
# it's idempotent so re-runs are safe.
try { mise --cd $HOME exec -- rtk init -g --auto-patch } catch { }

# Claude Code plugin marketplaces — clone newly-declared marketplaces and update the rest.
# Reads ~/.claude/settings.json (chezmoi-managed) for the declared set; plugins ship inside
# their marketplace repos, so this refreshes plugin code too. The fingerprint re-runs this
# script whenever the declared marketplaces change.
# marketplaces fingerprint: {{ include "dot_claude/settings.json" | fromJson | dig "extraKnownMarketplaces" dict | toJson | sha256sum }}
if (Get-Command claude -ErrorAction SilentlyContinue) { try { claude plugin marketplace update } catch { } }

{{ if .tools -}}
# delta: wire git via include.path (idempotent); identity stays in the unmanaged config.
if (Get-Command git -ErrorAction SilentlyContinue) {
  $deltaInc = Join-Path $HOME '.config/git/delta.gitconfig'
  if (((git config --global --get-all include.path) 2>$null) -notcontains $deltaInc) {
    git config --global --add include.path $deltaInc
  }
}
{{ end -}}

{{ if .wm -}}
# --- Windows tiling window manager (komorebi + whkd + yasb) — the `wm` profile,
#     analogue of the macOS yabai/skhd block. These live in scoop's extras bucket. ---
$buckets = scoop bucket list 2>$null | Out-String
if ($buckets -notmatch 'extras') { scoop bucket add extras }
scoop install komorebi whkd yasb
Write-Host "[wm] komorebi/whkd/yasb installed. Start the WM with: komorebic start --whkd"
Write-Host "[wm] Run yasb once (or add it to startup) to launch the status bar."
{{ end -}}

# --- wire the chezmoi-managed profile into the real $PROFILE for BOTH PowerShell 7
#     and Windows PowerShell 5.1. GetFolderPath('MyDocuments') is OneDrive-aware, so
#     this is correct even when Documents is redirected. Idempotent: only adds the
#     dot-source line once. ---
$Managed = Join-Path $XdgConfig 'powershell\profile.ps1'
$Docs = [Environment]::GetFolderPath('MyDocuments')
$ProfilePaths = @(
  (Join-Path $Docs 'PowerShell\Microsoft.PowerShell_profile.ps1'),        # PowerShell 7
  (Join-Path $Docs 'WindowsPowerShell\Microsoft.PowerShell_profile.ps1')  # Windows PowerShell 5.1
)
$ShimLine = ". '$Managed'"
foreach ($profilePath in $ProfilePaths) {
  New-Item -ItemType Directory -Force -Path (Split-Path $profilePath) | Out-Null
  if (-not (Test-Path $profilePath) -or
      -not (Select-String -Path $profilePath -SimpleMatch $Managed -Quiet)) {
    Add-Content -Path $profilePath -Value $ShimLine
  }
}
