watch_stylesheet: true
watch_config: true
debug: true

komorebi:
  start_command: "komorebic start --whkd"
  stop_command: "komorebic stop --whkd"
  reload_command: "komorebic stop --whkd; komorebic start --whkd"

bars:
  primary-bar:
    enabled: true
    screens: ["LG ULTRAWIDE"]
    class_name: "yasb-bar"
    alignment:
      position: "top"
      center: false
    blur_effect:
      enabled: true
      acrylic: false
      dark_mode: true
      round_corners: true
      border_color: None
    window_flags:
      always_on_top: false
      windows_app_bar: true
    dimensions:
      width: "100%"
      height: 34
    padding:
      top: 6
      left: 10
      bottom: 0
      right: 10
    widgets:
      left: ["home","komorebi_active_layout","active_window"]
      center: ["komorebi_workspaces"]
      right: ["systray","weather", "pomodoro","language", "media", "clock", "notifications","power_menu"]

  secondary-bar:
    enabled: true
    screens: ["EV2451"]
    class_name: "yasb-bar"
    alignment:
      position: "top"
      center: false
    blur_effect:
      enabled: true
      acrylic: false
      dark_mode: true
      round_corners: true
      border_color: None
    window_flags:
      always_on_top: false
      windows_app_bar: true
    dimensions:
      width: "100%"
      height: 34
    padding:
      top: 6
      left: 10
      bottom: 0
      right: 10
    widgets:
      left: ["home","komorebi_active_layout", "active_window"]
      center: ["media"]
      right: ["whkd","cpu","memory","wifi","volume","clock"]

widgets:
  # Left widgets (primary & secondary bars)
  home:
    type: "yasb.home.HomeWidget"
    options:
      label: "<span class='icon'></span>"
      menu_list:
      - { separator: true }
      - { title: "🖥️ This PC", command: "explorer.exe shell:MyComputerFolder" }
      - { title: "📥 Download (C:)", path: '{{ .chezmoi.homeDir | replace "/" "\\" }}\Downloads' }
      - { title: "💾 Data (D:)", path: "D:\\" }
      - { title: "🛠️ Workspace (F:)", path: "F:\\" }
      - { title: "📦 Portables (G:)", path: "G:\\Portables" }
      - { title: "🗃️ Extend (H:)", path: "H:\\" }
      - { title: "☁️ Dropbox", path: '{{ .chezmoi.homeDir | replace "/" "\\" }}\Documents\Dropbox' }

      power_menu: false

  komorebi_active_layout:
    type: "komorebi.active_layout.ActiveLayoutWidget"
    options:
      hide_if_offline: true
      label: "{icon}"
      layouts:
        - "bsp"
        - "columns"
        - "rows"
        - "grid"
        - "scrolling"
        - "vertical_stack"
        - "horizontal_stack"
        - "ultrawide_vertical_stack"
        - "right_main_vertical_stack"
      layout_icons:
        bsp: ""
        columns: ""
        rows: ""
        grid: "󰝘"
        scrolling: ""
        vertical_stack: ""
        horizontal_stack: ""
        ultrawide_vertical_stack: ""
        right_main_vertical_stack: ""
        monocle: ""
        maximized: ""
        floating: ""
        paused: "󰾉"
        tiling: "󰙀"
      callbacks:
        on_left: "toggle_layout_menu"
        on_middle: "toggle_tiling"
        on_right: "next_layout"

  active_window:
    type: "yasb.active_window.ActiveWindowWidget"
    options:
      label: "{win[title]}"
      label_alt: "[class_name='{win[class_name]}' exe='{win[process][name]}' hwnd={win[hwnd]}]"
      label_icon: true
      label_icon_size: 16
      max_length: 56

  # Center widgets
  komorebi_workspaces:
    type: "komorebi.workspaces.WorkspaceWidget"
    options:
      hide_if_offline: true
      animation: true

  media:
    type: "yasb.media.MediaWidget"
    options:
      label: "{title} - {artist}"
      hide_empty: true
      callbacks:
        on_left: "toggle_play_pause"
        on_right: "toggle_media_menu"
      show_thumbnail: true
      controls_left: true
      max_field_size:
        label: 20
        label_alt: 40
      scrolling_label:
        enabled: true
        update_interval_ms: 33
        style: "bounce-ease"  # can be "left", "right", "bounce", "bounce-ease"
        separator: "     "
        label_padding: 1
        # Easing curve params: https://www.desmos.com/calculator/j7eamemxzi
        ease_slope: 20
        ease_pos: 0.8
        ease_min: 0.5



  # Right widgets (primary bar)
  systray:
    type: "yasb.systray.SystrayWidget"
    options:
      class_name: "systray"
      label_collapsed: ""
      label_expanded: ""
      icon_size: 16
      pin_click_modifier: "alt"
      show_unpinned: false

  pomodoro:
    type: "yasb.pomodoro.PomodoroWidget"
    options:
      label: "<span>{icon}</span> {remaining}"
      work_duration: 25
      break_duration: 5
      long_break_duration: 15
      long_break_interval: 4
      auto_start_breaks: true
      auto_start_work: true
      sound_notification: true
      show_notification: true
      session_target: 8
      icons:
        work: ""
        break: ""
        paused: ""
      callbacks:
        on_left: "toggle_menu"
        on_middle: "reset_timer"
        on_right: "toggle_label"

  language:
    type: "yasb.language.LanguageWidget"
    options:
      label: "<span class='icon'></span> {lang[country_code]}"
      label_alt: "<span class='icon'></span> {lang[full_name]}"
      update_interval: 5
      callbacks:
        on_left: "toggle_menu"
        on_right: "toggle_label"

  volume:
    type: "yasb.volume.VolumeWidget"
    options:
      label: "<span class='icon'>{icon}</span>{level}"
      volume_icons:
        - "" # Icon for muted
        - "" # Icon for 0-10% volume
        - "" # Icon for 11-30% volume
        - "" # Icon for 31-60% volume
        - "" # Icon for 61-100% volume
      callbacks:
        on_left: "toggle_volume_menu"
        on_right: "toggle_mute"

  clock:
    type: "yasb.clock.ClockWidget"
    options:
      label: "{%H:%M}"
      label_alt: "{%m/%d (%a) %H:%M:%S}"
      callbacks:
        on_left: "toggle_calendar"
        on_right: "toggle_label"
      calendar:
        blur: true
        round_corners: true
        round_corners_type: "normal"
        border_color: "system"
        alignment: "center"
        direction: "down"
        offset_top: 6
        offset_left: 0
        show_holidays: true
        holiday_color: "#f38ba8"
        show_week_numbers: false
        show_years: false
        country_code: "JP"
        extended: false

  power_menu:
    type: "yasb.power_menu.PowerMenuWidget"
    options:
      label: "<span>⏻</span>"
      uptime: True
      show_user: false
      blur: false
      blur_background: true
      button_row: 5
      buttons:
        hibernate: ["󰜗", "Hibernate"]
        sleep: ["󰤄", "Sleep"]
        restart: ["󰜉", "Restart"]
        signout: ["󰍃", "Sign out"]
        shutdown: ["󰤆", "Shut Down"]
        cancel: ["", "Cancel"]

  # Right widgets (secondary bar)
  whkd:
    type: "yasb.whkd.WhkdWidget"
    options:
      label: "<span class='icon'></span>"
      special_keys:
        - key: "win"
          key_replace: ""
        - key: "ctrl"
          key_replace: "Ctrl"
        - key: "alt"
          key_replace: "Alt"
        - key: "shift"
          key_replace: "Shift"
        - key: "left"
          key_replace: "←"
        - key: "right"
          key_replace: "→"
        - key: "up"
          key_replace: "↑"
        - key: "down"
          key_replace: "↓"

  weather:
    type: "yasb.weather.WeatherWidget"
    options:
      label: "<span>{icon}</span> {temp}"
      label_alt: "{location}: Min {min_temp}, Max {max_temp}, Humidity {humidity}"
      api_key: "$env:YASB_WEATHER_API_KEY"
      show_alerts: true
      update_interval: 600
      hide_decimal: true
      units: "metric"
      location: "$env:YASB_WEATHER_LOCATION"
      callbacks:
        on_left: "toggle_card"
        on_right: "toggle_label"
      icons:
        sunnyDay: ""
        clearNight: ""
        cloudyDay: ""
        cloudyNight: ""
        rainyDay: ""
        rainyNight: ""
        # snowyIcyDay: "󰼶"
        # snowyIcyNight: "󰼶"
        blizzardDay: "󰼶"
        blizzardNight: "󰼶"
        foggyDay: ""
        foggyNight: ""
        thunderstormDay: ""
        thunderstormNight: ""
        default: ""

  cpu:
    type: "yasb.cpu.CpuWidget"
    options:
      label: "<span></span> {info[percent][total]}%"
      update_interval: 2000
      cpu_thresholds:
        low: 25
        medium: 50
        high: 90
      histogram_icons:
        - "▁" # 0%
        - "▁" # 10%
        - "▂" # 20%
        - "▃" # 30%
        - "▄" # 40%
        - "▅" # 50%
        - "▆" # 60%
        - "▇" # 70%
        - "█" # 80%+
      histogram_num_columns: 8
      callbacks:
        on_left: "exec cmd /c Taskmgr"
        on_right: "exec cmd /c Taskmgr"

  memory:
    type: "yasb.memory.MemoryWidget"
    options:
      label: "<span></span> {virtual_mem_percent}%"
      label_alt: "<span>MEM</span> {virtual_mem_free}/{virtual_mem_total}"
      update_interval: 5000
      callbacks:
        on_left: "toggle_label"
      memory_thresholds:
        low: 25
        medium: 50
        high: 90
      histogram_icons:
        - "▁" # 0%
        - "▁" # 10%
        - "▂" # 20%
        - "▃" # 30%
        - "▄" # 40%
        - "▅" # 50%
        - "▆" # 60%
        - "▇" # 70%
        - "█" # 80%+

  wifi:
    type: "yasb.wifi.WifiWidget"
    options:
      label: "<span class='icon'>{wifi_icon}</span> {wifi_name}"
      update_interval: 5000
      callbacks:
        on_left: "toggle_menu"
        on_middle: "exec cmd.exe /c start ms-settings:network"
        on_right: "do_nothing"
      get_exact_wifi_strength: false
      wifi_icons: [
        "",  # Icon for 0% strength
        "",  # Icon for 1-24% strength
        "",  # Icon for 25-49% strength
        "",  # Icon for 50-74% strength
        ""   # Icon for 75-100% strength
      ]
      menu_config:
        blur: true
        round_corners: true
        round_corners_type: "normal"
        border_color: "System"
        alignment: "right"
        direction: "down"
        offset_top: 6
        offset_left: 0
        wifi_icons_secured: [
          "",
          "",
          "",
          "",
        ]
        wifi_icons_unsecured: [
          "",
          "",
          "",
          "",
        ]

  notifications:
    type: "yasb.notifications.NotificationsWidget"
    options:
      label: "<span></span> {count}"
      label_alt: "{count} notifications"
      hide_empty: false
      tooltip: true
      callbacks:
        on_left: "toggle_notification"
        on_right: "do_nothing"
      label_shadow:
        enabled: true
        color: "black"
        radius: 3
        offset: [ 1, 1 ]
