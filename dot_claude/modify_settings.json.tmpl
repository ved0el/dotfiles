chezmoi:modify-template
{{- /*
  Synced Claude Code settings (modify-template). On apply, this reads the LIVE
  ~/.claude/settings.json (via .chezmoi.targetFile, which still holds the current
  contents at render time), FORCES the shared keys below from source, UNIONS a
  baseline into permissions.allow, and PRESERVES every other live key — so plugin
  toggles, marketplaces, and per-machine approved commands survive cza/czu, while
  hooks/model/statusLine/etc. sync everywhere.

  Change a SHARED key by editing THIS file (cze) — NOT the live file: a forced
  key's live value reverts on the next apply. czra does not capture modify-templates.
*/ -}}
{{- $cur := dict -}}
{{- if stat .chezmoi.targetFile -}}{{- $cur = include .chezmoi.targetFile | fromJson -}}{{- end -}}
{{- $r := deepCopy $cur -}}
{{- $statusCmd := "bash $HOME/.claude/statusline.sh" -}}
{{- if eq .chezmoi.os "windows" -}}
{{-   $statusCmd = printf "pwsh -NoLogo -NoProfile -File %s/.claude/statusline.ps1" .chezmoi.homeDir -}}
{{- end -}}
{{- /* ── forced shared keys ───────────────────────────────────────────── */ -}}
{{- $_ := set $r "skillListingBudgetFraction" 0.025 -}}
{{- $_ := set $r "env" (dict "ECC_DISABLED_HOOKS" "pre:config-protection,pre:edit-write:gateguard-fact-force") -}}
{{- $_ := set $r "model" "auto" -}}
{{- $_ := set $r "defaultMode" "auto" -}}
{{- $_ := set $r "hooks" (dict "PreToolUse" (list (dict "matcher" "Bash" "hooks" (list (dict "type" "command" "command" "rtk hook claude"))))) -}}
{{- $_ := set $r "statusLine" (dict "type" "command" "command" $statusCmd) -}}
{{- $_ := set $r "agentPushNotifEnabled" false -}}
{{- $_ := set $r "hasCompletedOnboarding" true -}}
{{- $_ := set $r "terminalProgressBarEnabled" false -}}
{{- /* ── union the shared approved-command baseline into the live allow list ─ */ -}}
{{- $baseAllow := list
      "Bash(ls:*)" "Bash(tree:*)" "Bash(npx:*)" "Bash(pnpx:*)" "Bash(pnpm:*)"
      "Bash(nvm use:*)" "Bash(printf:*)" "Bash(head:*)" "Bash(git:*)" "Bash(wc:*)" "Bash(find:*)"
      "mcp__codegraph__codegraph_explore" "mcp__codegraph__codegraph_search"
      "mcp__codegraph__codegraph_node" "mcp__codegraph__codegraph_callers"
      "mcp__codegraph__codegraph_callees" "mcp__codegraph__codegraph_impact"
      "mcp__codegraph__codegraph_files" "mcp__codegraph__codegraph_status" -}}
{{- $perm := dict -}}
{{- if hasKey $r "permissions" -}}{{- $perm = index $r "permissions" -}}{{- end -}}
{{- $curAllow := list -}}
{{- if hasKey $perm "allow" -}}{{- $curAllow = index $perm "allow" -}}{{- end -}}
{{- $_ := set $perm "allow" (concat $curAllow $baseAllow | uniq) -}}
{{- $_ := set $r "permissions" $perm }}
{{ $r | toPrettyJson -}}
