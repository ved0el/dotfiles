#!/usr/bin/env zsh
# Managed by chezmoi — edit with `chezmoi edit ~/.zshrc`, then `chezmoi apply`.
#
# Thin loader: every concern is a numbered module in ~/.config/zsh/conf.d/, sourced in order.
# Each module self-gates on `command -v` so it only configures tools that are actually installed.

#!/usr/bin/env zsh
# powerlevel10k instant prompt — MUST load first, before anything that outputs.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

for _f in "${XDG_CONFIG_HOME:-$HOME/.config}"/zsh/conf.d/*.zsh(N-.); do
  source "$_f"
done
unset _f
